// SPDX-License-Identifier: (GPL-2.0 OR MIT)
/*
 * Device-tree node for the Milan TSN NIC (kl,dma-ether). Overlay this onto the
 * SoC .dts (the LiteX-generated tree for the fully-FPGA NaxRiscv build, or the
 * Zynq PS .dtsi). Addresses match docs/REGISTER_MAP.md and the migration plan.
 *
 * Binding: sw/dts/bindings/kl,dma-ether.yaml. Requirements: docs/FR_NFR.md §2.11.
 */

/ {
	milan_eth: ethernet@43c00000 {
		compatible = "kl,dma-ether-0.9";
		status = "okay";

		/* CSR (milan_csr, 64 KB) + the three DMA register blocks (FR-DT-01).
		 * NOTE: the csr BASE is host-specific — 0x43c00000 on the Zynq PS, but
		 * 0x90000000 on the NaxRiscv/LiteX SoC (CPU IO region). Register offsets
		 * are identical; set this base to match the target (see sw/README.md). */
		reg = <0x43c00000 0x00010000>,   /* csr  (Zynq base; use 0x90000000 on RISC-V) */
		      <0x40410000 0x00010000>,   /* dma-tx (axi_dma eth MM2S/S2MM regs) */
		      <0x40410000 0x00010000>,   /* dma-rx (same engine, S2MM)          */
		      <0x40400000 0x00010000>;   /* dma-ts (ts-metadata S2MM)           */
		reg-names = "csr", "dma-tx", "dma-rx", "dma-ts";

		/* four IRQs into the SoC interrupt controller (FR-DT-02).
		 * On the RISC-V SoC use &plic; on Zynq this is the IRQ_F2P/&intc lines. */
		interrupt-parent = <&plic>;
		interrupts = <1>, <2>, <3>, <4>;
		interrupt-names = "tx-dma", "rx-dma", "ts-dma", "csr";

		/* queues (FR-DT-03): N TX/RX queues; only the listed ones are CBS-shaped.
		 * Reset policy = q0,q1 shaped (matches CBS_EN_RST, REGISTER_MAP §0x400). */
		kl,txq-cnt = <4>;
		kl,rxq-cnt = <4>;
		kl,shaped-queues = <0 1>;

		/* Ethernet / PHY (FR-DT-04, FR-DT-05) */
		local-mac-address = [00 1b c5 00 00 01];
		phy-mode = "rgmii-id";
		phy-handle = <&milan_phy>;
		phy-reset-gpios = <&gpio 0 1 /* GPIO_ACTIVE_LOW */>;

		/* PTP hardware clock (FR-DT-06): PHC on the 0x500 CSR block, disciplined
		 * from a fixed 125 MHz reference (REQ-PTP-07). */
		kl,ptp;
		kl,ptp-clock-hz = <125000000>;

		/* optional clocks (FR-DT-07); driver uses fixed rates if absent */
		/* clocks = <&clk_axis>, <&clk_gtx>, <&clk_ptp>;
		 * clock-names = "axis", "gtx", "ptp"; */

		/* subnodes must follow all properties (DTS rule) */
		mdio {
			#address-cells = <1>;
			#size-cells = <0>;
			milan_phy: ethernet-phy@1 {
				reg = <1>;         /* RTL8211 on the AX7101 PHY0 */
			};
		};
	};
};
