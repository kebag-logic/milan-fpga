+/* Milan Linux flash-boot: copy Linux images from the on-board QSPI flash into DRAM before
+   serialboot (priority -10 < serial's 0), so a normal power-on boots from flash with no --
+   or, for the partial manifest, minimal -- serial upload. Falls through to serialboot if the
+   flash is empty/updating. Enabled by milan_soc.py --with-spiflash (emits MILAN_FLASHBOOT_*). */
+#if defined(MILAN_FLASHBOOT_ENTRY) && defined(MAIN_RAM_BASE_VA) && !defined(MILAN_FLASHBOOT_DISABLE)
+#ifndef MILAN_FLASH_BOOT_PRIORITY
+#define MILAN_FLASH_BOOT_PRIORITY -10
+#endif
+static int milan_flash_boot_method(void)
+{
+	linux_flashboot();
+	return BOOT_METHOD_CONTINUE;
+}
+define_boot_method(milan_flash, milan_flash_boot_method, MILAN_FLASH_BOOT_PRIORITY);
+#endif
+
 #if defined(ROM_BOOT_ADDRESS) && !defined(ROM_BOOT_DISABLE)
 #ifndef ROM_BOOT_PRIORITY
 #define ROM_BOOT_PRIORITY 20
