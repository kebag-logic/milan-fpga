{
  "_schema": "kebag-logic/milan-aem-entity",
  "_schema_version": "1.0.0",
  "_description": "Single IEEE 1722.1-2021 AEM entity, AVnu Milan v1.2 profile. Byte-accurate mirror of the reference software entity in PipeWire module-avb (entity-model-milan-v12.h / aecp-vendor-unique-milan-v12.h). Drives BOTH the FPGA 4-level AEM memory (see ../aem-and-aecp.md) and a software entity. See ./README.md.",
  "spec": {
    "aem": "IEEE 1722.1-2021",
    "profile": "AVnu Milan v1.2",
    "avtp": "IEEE 1722-2016 (AAF / CRF stream formats)",
    "gptp": "IEEE 802.1AS",
    "sources_of_truth": [
      "srcs/buildroot/dl/pipewire-upstream/git/src/modules/module-avb/entity-model-milan-v12.h",
      "srcs/buildroot/dl/pipewire-upstream/git/src/modules/module-avb/aecp-vendor-unique-milan-v12.h",
      "milan-fpga/aem-and-aecp.md  (FPGA 4-level AEM memory + AECP state machines)"
    ],
    "field_class_legend": {
      "static": "compile-time constant; lives in factory read-only NVM / ROM. Never written by AECP.",
      "semi_static": "provisioned at build/first-boot (e.g. MAC-derived); NVM, rarely changes.",
      "nonvolatile": "settable by AECP (SET_NAME/SET_CONFIGURATION/...) and persisted; survives reboot, cleared by factory-reset.",
      "dynamic": "live state (SET_STREAM_FORMAT / SET_CLOCK_SOURCE / SET_CONTROL / counters / gPTP); volatile mirror, not persisted."
    },
    "convention": "A field written as a bare scalar is class=static. A field written as {value,class,access,...} carries its class and the AEM command that reads/writes it. Descriptor addressing is (configuration_index, descriptor_type, descriptor_index) which maps 1:1 onto the aem-and-aecp.md L1/L2/L3 memory levels."
  },

  "avtp_subtypes": { "ADP": "0xFA", "AECP": "0xFB", "ACMP": "0xFC", "MAAP": "0xFE" },

  "milan_mvu": {
    "_ref": "Milan v1.2 Sec 5.4.3 (AECP Vendor Unique / MVU)",
    "protocol_id": "00-1B-C5-0A-C1-00",
    "protocol_id_note": "Avnu OUI-36 00-1B-C5-0A-C + 12-bit MVU id 0x100.",
    "commands": {
      "GET_MILAN_INFO": "0x0000",
      "SET_SYSTEM_UNIQUE_ID": "0x0001",
      "GET_SYSTEM_UNIQUE_ID": "0x0002",
      "SET_MEDIA_CLOCK_REFERENCE_INFO": "0x0003",
      "GET_MEDIA_CLOCK_REFERENCE_INFO": "0x0004"
    },
    "commands_note": "GET_MILAN_INFO is confirmed in the reference SW header (AVB_AECP_MVU_CMD_GET_MILAN_INFO=0x0000). The SYSTEM_UNIQUE_ID and MEDIA_CLOCK_REFERENCE_INFO codes follow Milan v1.2 Sec 5.4 + aem-and-aecp.md; confirm the exact codes against the Milan v1.2 spec before wire use.",
    "get_milan_info_response": {
      "protocol_version": { "value": 1, "class": "static" },
      "features_flags": {
        "value": { "MILAN_REDUNDANCY": false },
        "raw_hex": "0x00000000",
        "class": "static",
        "note": "Seamless network redundancy is OUT OF SCOPE for now (single AVB_INTERFACE). MILAN_REDUNDANCY stays 0. Revisit if/when a 2nd MAC + redundant configuration is added."
      },
      "certification_version": { "value": "1.2.0.0", "raw_hex": "0x01020000", "class": "static" }
    },
    "system_unique_id": { "value": 0, "class": "nonvolatile", "note": "Milan grouping id; GET/SET via MVU." },
    "media_clock_reference_info": {
      "class": "dynamic",
      "note": "Milan v1.2 media-clock reference chain state (reference priority / domain). Exposed via GET/SET_MEDIA_CLOCK_REFERENCE_INFO; tracks the CLOCK_DOMAIN below."
    }
  },

  "adp": {
    "_ref": "IEEE 1722.1-2021 Sec 6 (ADP). HW advertiser mirrors these ENTITY fields.",
    "_note": "ADPDU body is 64 bytes; fields below are the advertised copy of the ENTITY descriptor. valid_time and available_index are owned by the HW ADP advertiser (Part B of the migration plan).",
    "valid_time_s": { "value": 62, "class": "static", "note": "Milan: 2*valid_time seconds re-advertise; must be >= 2 and even. 62 => advertise every ~31 s (Milan recommends valid_time such that re-advertise <= 5 s? use 4 => 2 s). Set per Milan v1.2 timing." },
    "available_index": { "value": 0, "class": "dynamic", "note": "Increments on every state change / re-advertise. MUST match ENTITY.available_index and never decrease without an entity restart." },
    "identify_control_index": { "value": 0, "class": "static", "note": "valid because entity_capabilities.AEM_IDENTIFY_CONTROL_INDEX_VALID is set => CONTROL[0]." },
    "interface_index": { "value": 0, "class": "static", "note": "valid because entity_capabilities.AEM_INTERFACE_INDEX_VALID is set => AVB_INTERFACE[0]." }
  },

  "counters": {
    "_ref": "GET_COUNTERS (AEM cmd 0x0029). IEEE 1722.1-2021 Table 7.130 (STREAM_INPUT), Sec 7.4.42 Table 7.51 (AVB_INTERFACE) + Milan v1.2.",
    "STREAM_INPUT": ["MEDIA_LOCKED","MEDIA_UNLOCKED","STREAM_INTERRUPTED","SEQ_NUM_MISMATCH","MEDIA_RESET","TIMESTAMP_UNCERTAIN","TIMESTAMP_VALID","TIMESTAMP_NOT_VALID","UNSUPPORTED_FORMAT","LATE_TIMESTAMP","EARLY_TIMESTAMP","FRAMES_RX","FRAMES_TX"],
    "STREAM_OUTPUT": ["STREAM_START","STREAM_STOP","MEDIA_RESET","TIMESTAMP_UNCERTAIN","FRAMES_TX"],
    "AVB_INTERFACE": ["LINK_UP","LINK_DOWN","FRAMES_TX","FRAMES_RX","RX_CRC_ERROR","GPTP_GM_CHANGED"]
  },

