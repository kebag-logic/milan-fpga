// Dynamic read-overlay sources
localparam [3:0] OVL_ENTITY_ID_C = 4'd0;
localparam [3:0] OVL_MODEL_ID_C = 4'd1;
localparam [3:0] OVL_ECAPS_C = 4'd2;
localparam [3:0] OVL_TALKER_SRC_C = 4'd3;
localparam [3:0] OVL_TALKER_CAP_C = 4'd4;
localparam [3:0] OVL_LISTEN_SINK_C = 4'd5;
localparam [3:0] OVL_LISTEN_CAP_C = 4'd6;
localparam [3:0] OVL_CTRL_CAP_C = 4'd7;
localparam [3:0] OVL_AVAIL_IDX_C = 4'd8;
localparam [3:0] OVL_ASSOC_ID_C = 4'd9;
localparam [3:0] OVL_CURRENT_CFG_C = 4'd10;
localparam [3:0] OVL_MAC_C = 4'd11;
localparam [3:0] OVL_CLOCK_ID_C = 4'd12;

// overlay lookup: rom addr -> {hit, source[3:0], byte_of_source[2:0]}
// byte_of_source 0 = MOST significant byte of the source value.
function automatic [7:0] aem_ovl_lookup(input [15:0] addr);
  begin
    aem_ovl_lookup = 8'h00;  // hit=0
    if (addr >= 16'd4 && addr < 16'd12)
      aem_ovl_lookup = {1'b1, OVL_ENTITY_ID_C, 3'(addr - 16'd4)};
    if (addr >= 16'd12 && addr < 16'd20)
      aem_ovl_lookup = {1'b1, OVL_MODEL_ID_C, 3'(addr - 16'd12)};
    if (addr >= 16'd20 && addr < 16'd24)
      aem_ovl_lookup = {1'b1, OVL_ECAPS_C, 3'(addr - 16'd20)};
    if (addr >= 16'd24 && addr < 16'd26)
      aem_ovl_lookup = {1'b1, OVL_TALKER_SRC_C, 3'(addr - 16'd24)};
    if (addr >= 16'd26 && addr < 16'd28)
      aem_ovl_lookup = {1'b1, OVL_TALKER_CAP_C, 3'(addr - 16'd26)};
    if (addr >= 16'd28 && addr < 16'd30)
      aem_ovl_lookup = {1'b1, OVL_LISTEN_SINK_C, 3'(addr - 16'd28)};
    if (addr >= 16'd30 && addr < 16'd32)
      aem_ovl_lookup = {1'b1, OVL_LISTEN_CAP_C, 3'(addr - 16'd30)};
    if (addr >= 16'd32 && addr < 16'd36)
      aem_ovl_lookup = {1'b1, OVL_CTRL_CAP_C, 3'(addr - 16'd32)};
    if (addr >= 16'd36 && addr < 16'd40)
      aem_ovl_lookup = {1'b1, OVL_AVAIL_IDX_C, 3'(addr - 16'd36)};
    if (addr >= 16'd40 && addr < 16'd48)
      aem_ovl_lookup = {1'b1, OVL_ASSOC_ID_C, 3'(addr - 16'd40)};
    if (addr >= 16'd310 && addr < 16'd312)
      aem_ovl_lookup = {1'b1, OVL_CURRENT_CFG_C, 3'(addr - 16'd310)};
    if (addr >= 16'd1106 && addr < 16'd1112)
      aem_ovl_lookup = {1'b1, OVL_MAC_C, 3'(addr - 16'd1106)};
    if (addr >= 16'd1114 && addr < 16'd1122)
      aem_ovl_lookup = {1'b1, OVL_CLOCK_ID_C, 3'(addr - 16'd1114)};
  end
endfunction

