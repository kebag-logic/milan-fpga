<mxfile host="app.diagrams.net"><diagram name="milan-system-map"><mxGraphModel dx="2000" dy="1400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="5240" pageHeight="2640" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="MILAN AVB NIC on VexiiRiscv SoC — FULL SYSTEM MAP (hierarchical)&#160;&#160;·&#160;&#160;AX7101 xc7a100t (Arty deltas noted)&#160;&#160;·&#160;&#160;block-in-block: memories live INSIDE their owner&#160;&#160;·&#160;&#160;every wire: bus width&#160;&#160;·&#160;&#160;colours = clock domains&#160;&#160;·&#160;&#160;2026-07-12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333;fontSize=20;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="5160" height="44" as="geometry"/></mxCell><mxCell id="lg1" value="sys @ 100 MHz (cd_sys)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="80" width="190" height="26" as="geometry"/></mxCell><mxCell id="lg2" value="milan datapath @ 100 MHz (cd_milan)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="262" y="80" width="214" height="26" as="geometry"/></mxCell><mxCell id="lg3" value="eth 125 MHz (LiteEth MAC/PHY)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="488" y="80" width="200" height="26" as="geometry"/></mxCell><mxCell id="lg4" value="off-chip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="700" y="80" width="100" height="26" as="geometry"/></mxCell><mxCell id="lg5" value="register file / BRAM / DRAM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="812" y="80" width="200" height="26" as="geometry"/></mxCell><mxCell id="lg6" value="arbiter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1024" y="80" width="90" height="26" as="geometry"/></mxCell><mxCell id="lg7" value="lanes: LE = little (tdata[7:0] = first wire byte) · BE = big (tdata[63:56] first — AECP parser chain only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="114" width="1054" height="26" as="geometry"/></mxCell><mxCell id="t_clk" value="clocks: osc 200 -&gt; PLL: cd_sys 100 · cd_sys4x 400+dqs90 (DDR3-800) · cd_idelay 200 · cd_milan 100 (Arty 50) · eth_rx/eth_tx 125&#10;crossings: AXI-Lite CSR sys&lt;-&gt;milan · MAC dual-clock FIFOs eth&lt;-&gt;milan · DMA engines in sys, AXIS FIFOs to milan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1160" y="80" width="1240" height="44" as="geometry"/></mxCell><mxCell id="c_soc" value="SoC / softcore — LiteX, cd_sys 100 MHz" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4eef8;strokeColor=#9673a6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="1"><mxGeometry x="40" y="180" width="1700" height="1000" as="geometry"/></mxCell><mxCell id="c_cpu" value="VexiiRiscv cluster (RV64IMA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf6fc;strokeColor=#9673a6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_soc"><mxGeometry x="20" y="40" width="520" height="260" as="geometry"/></mxCell><mxCell id="hart0" value="hart 0&#10;(lsu refill 8,&#10;prefetch rpt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_cpu"><mxGeometry x="20" y="40" width="230" height="80" as="geometry"/></mxCell><mxCell id="hart1" value="hart 1&#10;(1-hart decision pending:&#10;58% LUTs datapoint)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_cpu"><mxGeometry x="270" y="40" width="230" height="80" as="geometry"/></mxCell><mxCell id="l2" value="L2 cache — 64 KB shared (l2-bytes 65536)&#10;down-pending 8 · general-slots 16 · coherent DMA lands here" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_cpu"><mxGeometry x="20" y="135" width="480" height="70" as="geometry"/></mxCell><mxCell id="plic" value="PLIC + CLINT — IRQs: kl-eth per-queue · milan_csr o_irq_csr · UART · timer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_cpu"><mxGeometry x="20" y="210" width="480" height="40" as="geometry"/></mxCell><mxCell id="bus" value="LiteX interconnect&#10;&#10;Wishbone/AXI&#10;CSR bus 32b +&#10;coherent DMA port&#10;into the L2&#10;(--coherent-dma)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_soc"><mxGeometry x="580" y="40" width="210" height="260" as="geometry"/></mxCell><mxCell id="dramc" value="LiteDRAM controller&#10;A7DDRPHY (sys4x 400 + DQS 90°,&#10;200 MHz IDELAYCTRL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_soc"><mxGeometry x="830" y="40" width="280" height="120" as="geometry"/></mxCell><mxCell id="c_per" value="peripherals" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf6fc;strokeColor=#9673a6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_soc"><mxGeometry x="1130" y="40" width="550" height="260" as="geometry"/></mxCell><mxCell id="uart" value="UART 115200 (litex_term)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_per"><mxGeometry x="20" y="35" width="240" height="55" as="geometry"/></mxCell><mxCell id="jtag" value="JTAG — openFPGALoader&#10;ft232 210512180081" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_per"><mxGeometry x="280" y="35" width="250" height="55" as="geometry"/></mxCell><mxCell id="qspi" value="QSPI flash N25Q128 16 MB (off-chip, flashboot)&#10;kernel&#160;&#160;&#160;@ 0x00_0000&#160;&#160;(8.5 MiB budget)&#10;opensbi&#160;&#160;@ 0x88_0000&#160;&#160;(512 KiB, fw_jump)&#10;dtb&#160;&#160;&#160;&#160;&#160;&#160;@ 0x90_0000&#10;rootfs&#160;&#160;&#160;@ 0x94_0000&#160;&#160;(6.75 MiB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_per"><mxGeometry x="20" y="105" width="510" height="140" as="geometry"/></mxCell><mxCell id="c_dma" value="kl-eth DMA engines (fabric, cd_sys, coherent port into L2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf6fc;strokeColor=#9673a6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_soc"><mxGeometry x="20" y="340" width="780" height="620" as="geometry"/></mxCell><mxCell id="txrd" value="TX descriptor reader + HW-TSO&#10;&#10;fetches the 512x8B ring —&#10;base/length in BYTES (trap!) ·&#10;AXI bursts 16-64 beats x 64b&#10;(128-512 B) · TSO header-gen (MSS&#10;segmentation, chain-csum; TX&#10;143-&gt;186 zc) · reader-bound wall&#10;(starve 70% -&gt; prefetch next)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="20" y="40" width="360" height="280" as="geometry"/></mxCell><mxCell id="stag" value="TX staging FIFO — BRAM&#10;2048 beats x 64b = 16 KB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="30" y="330" width="340" height="60" as="geometry"/></mxCell><mxCell id="rxwr" value="RX writer&#10;&#10;RSC TCP coalescer (RING_RSC_TOUT,&#10;100 MHz ticks, default 250 us) ·&#10;header-split v3 (fill len in&#10;w0[31:16], page &lt;= 32 KB) · 4-slot&#10;writer + pop-ordered CQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="400" y="40" width="360" height="280" as="geometry"/></mxCell><mxCell id="steer" value="RX flow steer (2 queues)&#10;4-tuple hash -&gt; q0/q1 · hash_sel=1&#10;forces q0 (set BEFORE TCP runs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="410" y="330" width="340" height="90" as="geometry"/></mxCell><mxCell id="csrjson" value="LiteX CSR block @ 0xf000_0000&#10;ring ctl · RSC tout · steer/hash · IRQ status&#10;offsets BUILD-DEPENDENT: read csr.json!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="30" y="410" width="340" height="100" as="geometry"/></mxCell><mxCell id="irqn" value="IRQ fan-in -&gt; PLIC&#10;per-queue RX complete + TX done&#10;(rx-usecs-low moderation: +32%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dma"><mxGeometry x="410" y="440" width="340" height="70" as="geometry"/></mxCell><mxCell id="c_drv" value="software (Linux on the softcore)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf6fc;strokeColor=#9673a6;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_soc"><mxGeometry x="820" y="340" width="860" height="620" as="geometry"/></mxCell><mxCell id="kleth" value="kl-eth driver (kl,dma-ether · silicon; MODULE_VERSION gates identity)&#10;&#10;• 2 RX queues x threaded NAPI · RSC ON @250 us (ethtool -C rx-usecs live)&#10;• hs_pgsz=16384 &lt;-&gt; gateware --hs-page-bytes 16384 (STRICT pairing)&#10;• 4-slot RX + pop-ordered CQ · 60 KB order-4 buffers (mslot60)&#10;• HW-TSO · chain-csum · ack-merge tout 512 us&#10;• identity provisioning once/boot: devmem 0x9000_0600 (aecp_csr_setup.sh)&#10;• NEXT: PHC /dev/ptpN + SO_TIMESTAMPING (gPTP gate — HW_SW_SPLIT.md)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_drv"><mxGeometry x="20" y="40" width="820" height="280" as="geometry"/></mxCell><mxCell id="ptpd" value="linuxptp: ptp4l (802.1AS BMCA, servo) + phc2sys — in the rootfs, unvalidated until the PHC lands;&#10;then a small bridge writes GM id/domain -&gt; CSR 0x624/0x628 on change (fabric re-advertises + AS_PATH truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_drv"><mxGeometry x="20" y="340" width="820" height="90" as="geometry"/></mxCell><mxCell id="pw" value="PipeWire module-avb (future media plane): crafts AAF frames -&gt; kl-eth -&gt; fabric CBS class-A queue ·&#10;SRP/MSRP state machines · ACMP connection POLICY via mailbox (HW answers / SW decides)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_drv"><mxGeometry x="20" y="445" width="820" height="80" as="geometry"/></mxCell><mxCell id="peers" value="validation peers (via the AVB switch): milan_controller.py · la_avdecc enum-probe (Hive&#x27;s library) · tsn-gen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_drv"><mxGeometry x="20" y="540" width="820" height="60" as="geometry"/></mxCell><mxCell id="c_dram" value="DDR3 SDRAM — MT41K256M16 x16 · 512 MB @ 0x4000_0000 (off-chip, DDR3-800)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f7ee;strokeColor=#82b366;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="1"><mxGeometry x="1780" y="180" width="620" height="660" as="geometry"/></mxCell><mxCell id="bootimg" value="boot images (from QSPI flashboot)&#10;kernel @ 0x4000_0000 · dtb @ 0x40EF_0000 ·&#10;opensbi fw_jump @ 0x40F0_0000 · initrd @ 0x4100_0000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dram"><mxGeometry x="20" y="50" width="580" height="110" as="geometry"/></mxCell><mxCell id="txring" value="TX descriptor ring — 512 x 8 B = 4 KB&#10;(&gt;= 2 max-size frames; 8 frame slots) · driver-allocated&#10;descriptor: {addr, len, flags, TX ts window @ +0x3100}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dram"><mxGeometry x="20" y="180" width="580" height="90" as="geometry"/></mxCell><mxCell id="rxrings" value="RX rings (per queue x2) — 4 slots x 60 pages x 16 KB = 960 KB&#10;+ completion queue 8 entries, POP-ORDERED (mslot60 &lt;-&gt;&#10;build_r2slots STRICT pairing) · header-split pages: header in&#10;slot, payload in 16 KB pages · RX ts in descriptor window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dram"><mxGeometry x="20" y="290" width="580" height="130" as="geometry"/></mxCell><mxCell id="dramnote" value="any DRAM row miss costs 1424 ns (50% TLB + 50% DRAM) —&#10;the measured single-port latency ceiling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_dram"><mxGeometry x="20" y="440" width="580" height="60" as="geometry"/></mxCell><mxCell id="phy" value="RTL8211E PHY (off-chip) — GMII-strapped, 8-bit SDR (an RGMII read corrupts every byte: hardware-confirmed)&#10;1000BASE-T to the AVB switch&#160;&#160;·&#160;&#160;Arty: DP83848 MII 10/100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1780" y="880" width="620" height="160" as="geometry"/></mxCell><mxCell id="c_fab" value="milan_datapath — fabric, cd_milan 100 MHz (Arty: 50 MHz)&#160;&#160;·&#160;&#160;ALL AXIS links: 64b tdata + 8b tkeep + tvalid/tready/tlast, LE unless marked BE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fc;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="1"><mxGeometry x="2460" y="180" width="2740" height="2160" as="geometry"/></mxCell><mxCell id="c_mac" value="MilanMAC (LiteEth) — eth 125 MHz island" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf3e7;strokeColor=#d79b00;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_fab"><mxGeometry x="20" y="50" width="620" height="500" as="geometry"/></mxCell><mxCell id="phyif" value="LiteEthPHYGMII — gtx 125 MHz, tx_clk_invert,&#10;launch FFs IOB-packed (silicon placement rule)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_mac"><mxGeometry x="20" y="40" width="580" height="80" as="geometry"/></mxCell><mxCell id="maccore" value="LiteEthMACCore — preamble/SFD · CRC32 · padding ·&#10;PHY-width conversion 8b &lt;-&gt; 64b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_mac"><mxGeometry x="20" y="135" width="580" height="80" as="geometry"/></mxCell><mxCell id="macfifo" value="dual-clock stream FIFOs — eth_rx/eth_tx 125 &lt;-&gt; cd_milan 100" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_mac"><mxGeometry x="20" y="230" width="580" height="70" as="geometry"/></mxCell><mxCell id="lastbe" value="stream &lt;-&gt; AXIS adapter&#10;last_be (one-hot) &lt;-&gt; tkeep (mask)&#10;— the M-A3 &#x27;no frame on the wire&#x27; root cause" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_mac"><mxGeometry x="20" y="315" width="580" height="90" as="geometry"/></mxCell><mxCell id="macnote" value="Arty: LiteEthPHYMII (100M) · is_1g=0 -&gt; CBS slope wiring pending" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_mac"><mxGeometry x="20" y="420" width="580" height="60" as="geometry"/></mxCell><mxCell id="c_rx" value="RX pipeline (post-MAC -&gt; DMA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_fab"><mxGeometry x="680" y="50" width="2040" height="500" as="geometry"/></mxCell><mxCell id="ptprx" value="ptp_ts_top — RX timestamping&#10;&#10;per-frame RX timestamp captured into&#10;the DMA descriptor ts window&#10;(dts kl,dma-ts @ +0x3100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="20" y="40" width="440" height="200" as="geometry"/></mxCell><mxCell id="ptpcnt" value="PTP counter + CSR regs — 64b counter FF&#10;CSR 0x500-0x544: CTRL/INCR/ADJ/TWlo·hi/&#10;OFlo·hi/CMD/TRlo·hi/ILAT/ELAT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="30" y="150" width="420" height="80" as="geometry"/></mxCell><mxCell id="tcam" value="rx_mac_filter — TCAM dest-MAC filter&#10;&#10;ternary match · default-pass CSR bit ·&#10;miss + no-default -&gt; drop&#10;(never backpressures)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="520" y="40" width="460" height="200" as="geometry"/></mxCell><mxCell id="tcamarr" value="TCAM entry array — 16 x {key 48b + mask 48b&#10;+ action 8b} = 1664 b FF · programmed&#10;@ 0x700-0x718 (CTRL/K/M/ACT/CMD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="530" y="150" width="440" height="80" as="geometry"/></mxCell><mxCell id="tap" value="rx_axis_to_dma&#10;THE TAP POINT (post-filter)&#10;taps are copies — never stall" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="c_rx"><mxGeometry x="1040" y="90" width="320" height="90" as="geometry"/></mxCell><mxCell id="rmon" value="ethernet_events — RMON counters&#10;&#10;event capture fed by MAC pulses&#10;(rx/tx frames, CRC err, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="1420" y="40" width="560" height="200" as="geometry"/></mxCell><mxCell id="rmonregs" value="event counters — 9 x 32b FF · RO @ 0x210-0x230&#10;(STAT0..8, stride 4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_rx"><mxGeometry x="1430" y="150" width="540" height="70" as="geometry"/></mxCell><mxCell id="c_atdecc" value="ATDECC control plane — zero-CPU responders (ADP · AECP · ACMP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_fab"><mxGeometry x="680" y="590" width="2040" height="900" as="geometry"/></mxCell><mxCell id="c_aecp" value="KL_aecp_top — AECP/AEM entity (§5.4, la_avdecc-clean)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fc;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_atdecc"><mxGeometry x="20" y="40" width="660" height="840" as="geometry"/></mxCell><mxCell id="aecppipe" value="ingress MONITOR tap (registered) -&gt; packet_validator -&gt;&#10;common_parser [internal links 64b AXIS BE] -&gt; l0_state&#10;(LOCK 60 s / ACQUIRE=NOT_SUPPORTED) -&gt; response_builder&#10;(segment engine NONE/ECHO/STORE/CONST x4 · CDL = frame-26)&#10;&#10;commands: READ_DESCRIPTOR · GET/SET names · config ·&#10;sampling-rate · stream-format · GET_STREAM_INFO (56 B) ·&#10;GET_AVB_INFO · GET_COUNTERS (136 B, full-size on errors) ·&#10;GET_AS_PATH · MVU GET_MILAN_INFO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_aecp"><mxGeometry x="15" y="35" width="630" height="260" as="geometry"/></mxCell><mxCell id="aecpbuf" value="ingress frame buf&#10;128 B LUTRAM (MAX_FRAME_BYTES)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_aecp"><mxGeometry x="15" y="310" width="300" height="80" as="geometry"/></mxCell><mxCell id="aecpwork" value="builder working set&#10;buf_r 64 B FF (capture) ·&#10;const_q 64 B FF (payloads)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_aecp"><mxGeometry x="340" y="310" width="305" height="80" as="geometry"/></mxCell><mxCell id="aemstore" value="AEM store — BRAM 808 B (byte port 8b, addr 16b, 1-cycle latency)&#10;directory 5 x 64b FF {type, idx, base, len}:&#10;&#160;&#160;ENTITY@0x000/312 · CONFIG@0x138/86 · AUDIO_UNIT@0x18E/156 ·&#10;&#160;&#160;STREAM_OUTPUT@0x22A/156 · AVB_INTERFACE@0x2C6/98&#10;write-back (volatile): names @48/180/316/402/558/714 (64 B each) ·&#10;&#160;&#160;sampling_rate @534 (4 B) · stream_format @628 (8 B)&#10;overlay: live CSR wins (eid, MAC, caps, avail_idx, cfg, clock_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_aecp"><mxGeometry x="15" y="405" width="630" height="190" as="geometry"/></mxCell><mxCell id="aecpcsr" value="status -&gt; CSR: 0x648 {locked, cmd_count} · 0x64C {resp_count, cfg}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_aecp"><mxGeometry x="15" y="610" width="630" height="60" as="geometry"/></mxCell><mxCell id="c_acmp" value="KL_acmp_responder — ACMP stateless talker (§5.5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef4fc;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_atdecc"><mxGeometry x="710" y="40" width="620" height="420" as="geometry"/></mxCell><mxCell id="acmppipe" value="same registered-tap pattern · 70 B ACMPDU (CDL 44)&#10;&#10;GET_TX_STATE -&gt; SUCCESS, count=0, stream fields zeroed,&#10;probe flags cleared (uid != 0 -&gt; TALKER_UNKNOWN_ID)&#10;GET_TX_CONNECTION -&gt; NOT_SUPPORTED (Milan 5.5.4.4)&#10;CONNECT/DISCONNECT_TX -&gt; NOT_SUPPORTED until the&#10;softcore policy mailbox (HW answers / SW decides)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_acmp"><mxGeometry x="15" y="35" width="590" height="230" as="geometry"/></mxCell><mxCell id="acmpbuf" value="frame buf — 72 B LUTRAM&#10;(9 beats x 8 B)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_acmp"><mxGeometry x="15" y="280" width="280" height="70" as="geometry"/></mxCell><mxCell id="acmpcsr" value="status -&gt; CSR 0x650&#10;{resp_count[31:16], cmd_count[15:0]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_acmp"><mxGeometry x="315" y="280" width="290" height="70" as="geometry"/></mxCell><mxCell id="c_adp" value="adp_advertiser — ADP (§6.2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fdf3e7;strokeColor=#d79b00;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_atdecc"><mxGeometry x="710" y="480" width="620" height="400" as="geometry"/></mxCell><mxCell id="adppipe" value="82 B ADPDU (CDL 0x38) · periodic every valid_time s&#10;(vt=31 -&gt; validity 62 s) · AVAILABLE / DEPARTING /&#10;discover response · available_index +1 on EVERY ADPDU&#10;(la_avdecc strict rule) · trigger priority: depart &gt;&#10;link_up &gt; info/gm change &gt; discover &gt; timer ·&#10;enable-edge with link already up == link_up (boot-order fix)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_adp"><mxGeometry x="15" y="35" width="590" height="230" as="geometry"/></mxCell><mxCell id="adpidx" value="available_index — 32b FF&#10;RO @ 0x644 (live counter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_adp"><mxGeometry x="15" y="280" width="290" height="60" as="geometry"/></mxCell><mxCell id="adpid" value="identity inputs = the CSR 0x600&#10;group (shared with the AEM&#10;overlay -&gt; cannot diverge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_adp"><mxGeometry x="325" y="280" width="280" height="90" as="geometry"/></mxCell><mxCell id="mux1" value="aecp_acmp_mux (adp_tx_arbiter)&#10;frame-atomic round-robin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_atdecc"><mxGeometry x="1400" y="120" width="280" height="90" as="geometry"/></mxCell><mxCell id="mux2" value="ctl_tx_mux&#10;ADP + (AECP|ACMP)&#10;frame-atomic round-robin" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_atdecc"><mxGeometry x="1400" y="300" width="280" height="90" as="geometry"/></mxCell><mxCell id="csr" value="milan_csr — REGISTER FILE (~46 x 32b FF)&#10;AXI-Lite slave @ 0x9000_0000 (64 KB window, data 32b,&#10;addr 16b) · cd_sys side, CDC into cd_milan&#10;(cdc_pulse / cdc_handshake for strobes)&#10;&#10;groups:&#10;&#160;&#160;0x000 ID/VERSION/CAP&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;0x108 station MAC&#10;&#160;&#160;0x210 RMON STAT0..8&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;0x300 classifier maps&#10;&#160;&#160;0x400 CBS slopes (x4 q)&#160;&#160;&#160;&#160;&#160;0x500 PTP group&#10;&#160;&#160;0x600 ADP identity&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;0x640 ADP cmd/status&#10;&#160;&#160;0x648/0x64C AECP status&#160;&#160;&#160;&#160;&#160;0x650 ACMP status&#10;&#160;&#160;0x700 TCAM programming&#10;&#10;o_irq_csr -&gt; PLIC · identity fans out to ADP + AEM +&#10;ACMP: ONE source of wire truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_atdecc"><mxGeometry x="1400" y="480" width="600" height="400" as="geometry"/></mxCell><mxCell id="c_tx" value="TX pipeline (DMA -&gt; shaped wire; control merged in gaps)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#6c8ebf;verticalAlign=top;align=left;fontSize=13;fontStyle=1;spacingLeft=10;spacingTop=2;container=1;collapsible=0;" vertex="1" parent="c_fab"><mxGeometry x="20" y="1520" width="2700" height="560" as="geometry"/></mxCell><mxCell id="cls" value="traffic_classifier (802.1Q)&#10;&#10;VLAN TPID 0x8100 parse · PCP[3b] -&gt;&#10;regen -&gt; traffic class -&gt; queue select ·&#10;AVTP ethertype 0x22F0 -&gt; class A/B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="20" y="50" width="480" height="220" as="geometry"/></mxCell><mxCell id="clsregs" value="classifier map registers (FF)&#10;PCP regen 8x3b · prio-&gt;TC 8x2b · TC-&gt;queue 4x2b&#10;@ 0x300 CTRL · 0x308 MAP · 0x30C REGEN · 0x310 TCQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="30" y="170" width="460" height="90" as="geometry"/></mxCell><mxCell id="queues" value="traffic_queues — BRAM&#10;&#10;4 x axis_fifo, 16 KB each&#10;(DEPTH 16384 bytes @ 64b) = 64 KB total&#10;per-queue depth/empty -&gt; shaper gating&#10;(fabric-internal, no bus address)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="540" y="50" width="480" height="220" as="geometry"/></mxCell><mxCell id="cbs" value="traffic_shaping_core + CBS&#10;&#10;credit gate + strict-priority across 4&#10;queues (802.1Q Table 8-5) · sequential&#10;slope engine (-8K LUTs, bit-exact, config&#10;latency 2 us) · NEVER removed (user rule)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="1060" y="50" width="480" height="220" as="geometry"/></mxCell><mxCell id="cbsregs" value="CBS register file (per queue x4)&#10;idleSlope 32b + credit/limit regs · @ 0x400 stride 0x20&#10;reset idleSlopes {300,200,150,100} Mb/s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="1070" y="170" width="460" height="90" as="geometry"/></mxCell><mxCell id="ptptx" value="ptp_ts_top — TX timestamping&#10;&#10;same 64b counter · per-frame TX&#10;timestamp -&gt; ts window -&gt; driver&#10;(SO_TIMESTAMPING once the PHC lands)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="1580" y="50" width="420" height="220" as="geometry"/></mxCell><mxCell id="dparb" value="adp_tx_mux — datapath merge&#10;&#10;shaped data has priority; control&#10;(ADP/AECP/ACMP) inserted in inter-&#10;frame gaps only: zero mid-frame jitter ·&#10;frame-atomic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="2040" y="50" width="400" height="220" as="geometry"/></mxCell><mxCell id="txnote" value="order on the wire: TX reader (SoC, cd_sys) -&gt; async FIFO -&gt; classifier -&gt; queues -&gt; CBS -&gt; PTP TX stamp -&gt; datapath merge -&gt; MAC -&gt; PHY&#160;&#160;·&#160;&#160;all hops 64b AXIS LE k8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="c_tx"><mxGeometry x="20" y="300" width="2420" height="60" as="geometry"/></mxCell><mxCell id="es1" value="ibus/dbus 64b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="c_cpu" target="bus"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es2" value="membus 64b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="bus" target="dramc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es2b" value="DDR3 x16 @ 400 MHz (DQ 16b DDR)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="dramc" target="c_dram"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es3" value="CSR 32b · coherent DMA 64b (via L2)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="bus" target="c_dma"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es4" value="AXI reads 64b, bursts 16-64 beats" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="txrd" target="txring"><mxGeometry relative="1" as="geome