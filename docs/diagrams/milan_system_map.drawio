<mxfile host="app.diagrams.net"><diagram name="milan-system-map"><mxGraphModel dx="2000" dy="1400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="5680" pageHeight="2400" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="MILAN AVB NIC on VexiiRiscv SoC — FULL SYSTEM MAP&#160;&#160;·&#160;&#160;AX7101 xc7a100t&#160;&#160;·&#160;&#160;data flows LEFT-&gt;RIGHT (RX lane top; TX lane bottom returns to the wire)&#160;&#160;·&#160;&#160;BIG arrows = frame/bus data · thin dashed = configuration/status · big dashed = monitor copy&#160;&#160;·&#160;&#160;every address = its own cell&#160;&#160;·&#160;&#160;2026-07-12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333;fontSize=18;verticalAlign=middle;align=center;spacingLeft=5;spacingRight=5;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="14" width="5600" height="42" as="geometry"/></mxCell><mxCell id="lg1" value="sys @ 100 MHz (cd_sys)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=5;spacingRight=5;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="180" height="26" as="geometry"/></mxCell><mxCell id="lg2" value="milan datapath @ 100 MHz (cd_milan)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=center;spacingLeft=5;spacingRight=5;" vertex="1" parent="1"><mxGeometry x="232" y="70" width="210" height="26" as="geometry"/></mxCell><mxCell id="lg3" value="eth 125 MHz (LiteEth MAC/PHY)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=center;spacingLeft=5;spacingRight=5;" vertex="1" parent="1"><mxGeometry x="454" y="70" width="190" height="26" as="geometry"/></mxCell><mxCell id="lg4" value="off-chip" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;s