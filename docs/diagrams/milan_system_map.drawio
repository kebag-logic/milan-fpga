<mxfile host="app.diagrams.net"><diagram name="milan-system-map"><mxGraphModel dx="2000" dy="1400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="4640" pageHeight="2980" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="MILAN AVB NIC on VexiiRiscv SoC — THE FULL SYSTEM MAP&#160;&#160;·&#160;&#160;AX7101 xc7a100t (board of record; Arty deltas noted)&#160;&#160;·&#160;&#160;every edge: width + lane convention&#160;&#160;·&#160;&#160;colours = clock domains&#160;&#160;·&#160;&#160;2026-07-12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333;fontSize=20;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="4560" height="44" as="geometry"/></mxCell><mxCell id="g_leg" value="legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="76" width="1180" height="96" as="geometry"/></mxCell><mxCell id="lg1" value="sys @ 100 MHz (cd_sys)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="106" width="190" height="26" as="geometry"/></mxCell><mxCell id="lg2" value="milan datapath @ 100 MHz (cd_milan)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="262" y="106" width="210" height="26" as="geometry"/></mxCell><mxCell id="lg3" value="eth_rx / eth_tx @ 125 MHz (LiteEth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="484" y="106" width="210" height="26" as="geometry"/></mxCell><mxCell id="lg4" value="off-chip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="706" y="106" width="120" height="26" as="geometry"/></mxCell><mxCell id="lg5" value="memory / table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="838" y="106" width="150" height="26" as="geometry"/></mxCell><mxCell id="lg6" value="arbiter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1000" y="106" width="100" height="26" as="geometry"/></mxCell><mxCell id="lg7" value="lane conventions:&#160;&#160;LE = little lane (tdata[7:0] = first wire byte, Forencich/MAC)&#160;&#160;&#160;BE = big lane (tdata[63:56] first — AECP parser chain only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="138" width="1040" height="26" as="geometry"/></mxCell><mxCell id="g_clk" value="clock tree (S7 PLL, from 200 MHz osc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="1260" y="76" width="1150" height="96" as="geometry"/></mxCell><mxCell id="t_clk" value="osc 200 MHz -&gt; PLL: cd_sys 100 MHz · cd_sys4x 400 + dqs(90deg) (DDR3-800) · cd_idelay 200 · cd_milan 100 (own domain since M-A2; Arty: 50)&#10;LiteEth PHY: eth_rx = PHY rx_clk 125 · eth_tx = gtx 125 (tx_clk_invert on AX7101; GMII launch FFs IOB-packed — silicon rule)&#10;crossings: AXI-Lite CSR sys&lt;-&gt;milan (bus CDC) · MAC core async FIFOs eth&lt;-&gt;milan · DMA engines in sys, AXIS FIFOs to milan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1280" y="106" width="1110" height="60" as="geometry"/></mxCell><mxCell id="g_soc" value="SoC / softcore&#160;&#160;(LiteX, cd_sys 100 MHz)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="2360" height="560" as="geometry"/></mxCell><mxCell id="cpu" value="VexiiRiscv x2 harts (RV64IMA)&#10;&#10;L2 64 KB (l2-bytes 65536)&#10;lsu-l1-refill-count=8&#10;lsu-hardware-prefetch=rpt&#10;l2-down-pending=8 · l2-general-slots=16&#10;(1-hart decision pending: 58% LUTs datapoint)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="250" width="330" height="150" as="geometry"/></mxCell><mxCell id="plic" value="PLIC + CLINT&#160;&#160;(IRQs: milan_csr o_irq_csr,&#10;kl-eth DMA per-queue, UART, timer)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="416" width="330" height="54" as="geometry"/></mxCell><mxCell id="bus" value="LiteX interconnect&#10;&#10;Wishbone/AXI&#10;32-bit CSR bus&#10;+ coherent DMA port&#10;into the CPU L2&#10;(--coherent-dma)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="430" y="250" width="210" height="220" as="geometry"/></mxCell><mxCell id="dram" value="LiteDRAM&#160;&#160;DDR3-800&#10;MT41K256M16 x16 · 512 MB&#10;(sys4x 400 MHz + DQS 90°, A7DDRPHY,&#10;200 MHz IDELAYCTRL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="670" y="250" width="300" height="110" as="geometry"/></mxCell><mxCell id="uart" value="UART 115200&#10;(litex_term)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="670" y="372" width="140" height="44" as="geometry"/></mxCell><mxCell id="jtag" value="JTAG (openFPGALoader&#10;ft232 210512180081)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="822" y="372" width="148" height="44" as="geometry"/></mxCell><mxCell id="qspi" value="QSPI N25Q128 16 MB (flashboot full)&#10;kernel@0 (8.5MiB) · opensbi@0x880000 ·&#10;dtb@0x900000 · rootfs@0x940000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="670" y="428" width="300" height="60" as="geometry"/></mxCell><mxCell id="t_socmap_t" value="memory map" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="250" width="660" height="24" as="geometry"/></mxCell><mxCell id="t_socmap" value="SoC address map (VexiiRiscv view)&#10;0x4000_0000&#160;&#160;DRAM 512 MB&#160;&#160;&#160;kernel@+0 · dtb@0x40EF_0000 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;opensbi fw_jump@0x40F0_0000 · initrd@0x4100_0000&#10;0x9000_0000&#160;&#160;milan_csr AXI-Lite window (64 KB, ADDR_WIDTH=16)&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;== the NIC datapath CSR block (map below)&#10;0xf000_0000&#160;&#160;LiteX CSRs: UART/timer/SPI/ctrl + kl-eth DMA block&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;(ring ctl, RSC tout, steer/hash, IRQ status —&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;offsets are BUILD-DEPENDENT: read csr.json, never&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;hardcode; e.g. steer q0/q1 telemetry moved between&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;P4/P8 cells)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1000" y="274" width="660" height="172" as="geometry"/></mxCell><mxCell id="kleth" value="kl-eth Linux driver&#160;&#160;(kl,dma-ether · silicon; MODULE_VERSION gates identity)&#10;&#10;• 2 RX queues (flow-steered) x threaded NAPI; RX rings in DRAM; budget/gro knobs&#10;• RSC ON by default @250 us (ethtool -C rx-usecs retunes RING_RSC_TOUT live; rsc_clk_mhz=100)&#10;• header-split hs_pgsz=16384 — MUST match gateware --hs-page-bytes 16384 (STRICT pairing)&#10;• multi-slot RX: 4 slots, pop-ordered CQ (wedge-free by construction), 60 KB order-4 buffers&#10;• HW-TSO on TX (header-gen in fabric) · chain-csum · ethtool -C ack-merge tout 512 us&#10;• identity provisioning once per boot: devmem into 0x9000_0600 group (aecp_csr_setup.sh)&#10;• NEXT: PHC /dev/ptpN + SO_TIMESTAMPING (gPTP gate — ARCHITECTURE_HW_SW_SPLIT.md)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1690" y="250" width="690" height="240" as="geometry"/></mxCell><mxCell id="sw2" value="userspace: linuxptp ptp4l+phc2sys (present, unvalidated until PHC) · PipeWire module-avb (future media: AAF frames -&gt; kl-eth -&gt; CBS class-A queue) · milan_controller.py / la_avdecc / Hive on the peer validate over the AVB switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1690" y="506" width="690" height="80" as="geometry"/></mxCell><mxCell id="dmaeng" value="kl-eth DMA engines (fabric, cd_sys, coherent port)&#10;&#10;TX reader: descriptor ring 512 x 8 B = 4 KB (&gt;= 2 max frames,&#10;8 frame slots) · staging FIFO 2048 beats (16 KB) · AXI bursts&#10;16-64 beats (128-512 B) · base/length in BYTES (trap!)&#10;+ HW-TSO header generator (validated TX 143-&gt;186 zc)&#10;&#10;RX writer: per-queue 4 slots x 60 pages x 16 KB = 960 KB/queue&#10;· completion queue depth 8, pop-ordered (mslot60) ·&#10;RSC coalescer (tout in 100 MHz ticks) · header-split v3&#10;(page fill length in w0[31:16], page &lt;= 32 KB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="430" y="500" width="540" height="240" as="geometry"/></mxCell><mxCell id="steer" value="RX flow steer (2 queues)&#10;4-tuple hash (IPv4/TCP ihl5) -&gt; q0/q1;&#10;hash_sel=1 forces q0 (set BEFORE TCP&#10;runs — silicon rule) · q0/q1 frame&#10;telemetry CSRs (csr.json)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1000" y="500" width="330" height="130" as="geometry"/></mxCell><mxCell id="irqn" value="IRQ fan-in&#10;per-queue RX complete + TX done +&#10;milan_csr o_irq_csr -&gt; PLIC&#10;(rx-usecs-low moderation: +32%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1000" y="644" width="330" height="96" as="geometry"/></mxCell><mxCell id="es1" value="ibus/dbus" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="cpu" target="bus"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es2" value="LiteDRAM port" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="bus" target="dram"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es3" value="CSR + coherent DMA (via L2)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="bus" target="dmaeng"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es4" value="AXI bursts 128-512 B" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="dmaeng" target="dram"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es5" value="rings/doorbells (csr.json offsets)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="kleth" target="dmaeng"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es6" value="M/S-ext IRQ" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="plic" target="cpu"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="irqn" target="plic"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="es8" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="dmaeng" target="steer"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="g_dp" value="milan_datapath (fabric, cd_milan 100 MHz — Arty: 50 MHz)&#160;&#160;&#160;·&#160;&#160;&#160;ALL internal links: AXI4-Stream 64-bit tdata + 8-bit tkeep + tvalid/tready/tlast, LITTLE lane unless marked BE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="4560" height="1130" as="geometry"/></mxCell><mxCell id="phy" value="RTL8211E PHY&#10;(GMII-strapped,&#10;8-bit SDR — an&#10;RGMII read corrupts&#10;every byte:&#10;hardware-confirmed)&#10;&#10;1000BASE-T&#10;to the AVB switch&#10;(MOTU/peer segment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="900" width="190" height="560" as="geometry"/></mxCell><mxCell id="mac" value="MilanMAC&#160;&#160;(LiteEth)&#10;&#10;LiteEthPHYGMII (gtx 125, tx_clk_invert,&#10;launch FFs IOB-packed — placement rule)&#10;+ LiteEthMACCore: preamble/SFD, CRC32,&#10;padding, PHY-width conversion 8b&lt;-&gt;64b,&#10;async FIFOs eth_rx/eth_tx &lt;-&gt; cd_milan&#10;+ stream&lt;-&gt;AXIS adapter:&#10;last_be (one-hot) &lt;-&gt; tkeep (mask)&#10;(the M-A3 no-frame-on-wire root cause)&#10;&#10;Arty: LiteEthPHYMII (DP83848, 100M,&#10;is_1g=0 -&gt; CBS slope wiring pending)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="300" y="900" width="330" height="560" as="geometry"/></mxCell><mxCell id="ptprx" value="ptp_ts_top — RX stamp&#10;&#10;64-bit free-running counter (cd_milan)&#10;per-frame RX timestamp captured -&gt;&#10;DMA descriptor ts window&#10;ptp_csr_sync: counter readable over CSR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="680" y="900" width="300" height="130" as="geometry"/></mxCell><mxCell id="tcam" value="rx_mac_filter (TCAM)&#10;&#10;16 entries x {key 48b, mask 48b} on dst&#10;MAC + action 8b · ternary match ·&#10;default-pass CSR bit · programmed at&#10;0x700-0x718 (CTRL/KLO/KHI/MLO/MHI/ACT/CMD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1030" y="900" width="320" height="130" as="geometry"/></mxCell><mxCell id="rxnode" value="rx_axis_to_dma&#10;(the tap point — post-filter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1400" y="935" width="260" height="60" as="geometry"/></mxCell><mxCell id="rsc" value="RX DMA front (cd_sys side)&#10;&#10;RSC TCP coalescer (RING_RSC_TOUT,&#10;100 MHz ticks; default 250 us) ·&#10;header-split v3 (16 KB pages) ·&#10;4-slot writer + CQ(8) pop-ordered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1710" y="900" width="330" height="130" as="geometry"/></mxCell><mxCell id="rxring" value="RX rings in DRAM (per queue)&#10;&#10;4 slots x 60 pages x 16 KB = 960 KB&#10;descriptors: {addr, len, flags, ts window&#10;(w/ RX timestamp), page-fill w0[31:16]}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2090" y="900" width="300" height="130" as="geometry"/></mxCell><mxCell id="er0" value="GMII 8b @125 (rx_clk)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#d79b00;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="phy" target="mac"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er1" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="mac" target="ptprx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er2" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="ptprx" target="tcam"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er3" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="tcam" target="rxnode"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er4" value="64b AXIS LE k8 (async FIFO to cd_sys)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="rxnode" target="rsc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er5" value="coherent AXI (via L2)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="rsc" target="rxring"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="aecp" value="KL_aecp_top — AECP/AEM entity (Milan v1.2 §5.4, la_avdecc-clean)&#10;&#10;ingress MONITOR tap (registered, never backpressures)&#10;-&gt; validator -&gt; parser [64b AXIS BE internally] -&gt; l0 (LOCK 60s /&#10;ACQUIRE=NOT_SUPPORTED) -&gt; response_builder (segment engine:&#10;NONE/ECHO/STORE/CONST x4, CDL=frame-26)&#10;&lt;-&gt; accessor/store/dyn_mux: dir 5 x 64b {type,idx,base,len} ·&#10;ROM 808 B x 8b byte port (1-cycle) · write-back names/rate/fmt ·&#10;live overlay (entity_id, MAC, caps, avail_idx, cfg, clock_id)&#10;commands: READ_DESCRIPTOR · names · config · rate · format ·&#10;STREAM_INFO(56B) · AVB_INFO · COUNTERS(136B) · AS_PATH · MVU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1400" y="1090" width="430" height="260" as="geometry"/></mxCell><mxCell id="acmp" value="KL_acmp_responder — ACMP stateless talker (§5.5)&#10;&#10;same registered-tap pattern · 70 B ACMPDU (CDL 44)&#10;GET_TX_STATE -&gt; SUCCESS, count=0, stream fields&#10;zeroed, probe flags cleared (uid!=0 -&gt; TALKER_&#10;UNKNOWN_ID) · GET_TX_CONNECTION -&gt; NOT_SUPPORTED&#10;(Milan 5.5.4.4) · CONNECT/DISCONNECT_TX -&gt; NOT_&#10;SUPPORTED until the softcore policy mailbox&#10;(HW answers / SW decides — HW_SW_SPLIT.md)&#10;counters -&gt; CSR 0x650" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1880" y="1090" width="380" height="260" as="geometry"/></mxCell><mxCell id="adp" value="adp_advertiser — ADP (§6.2)&#10;&#10;82 B ADPDU (CDL 0x38) · periodic every&#10;valid_time s (vt=31 -&gt; validity 62 s) ·&#10;ENTITY_AVAILABLE / DEPARTING / discover&#10;response · available_index +1 on EVERY&#10;ADPDU (la_avdecc strict rule) · trigger&#10;priority: depart &gt; link_up &gt; info/gm&#10;change &gt; discover &gt; timer · enable-edge&#10;with link up == link_up (boot-order fix)&#10;identity: the 0x600 CSR group (shared&#10;with AEM overlay — cannot diverge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2310" y="1090" width="360" height="260" as="geometry"/></mxCell><mxCell id="et1" value="tap (copy) 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="rxnode" target="aecp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et2" value="tap (copy) 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="rxnode" target="acmp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et3" value="ENTITY_DISCOVER pulse" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="aecp" target="adp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="mux1" value="aecp_acmp_mux&#10;(adp_tx_arbiter)&#10;frame-atomic RR&#10;64b AXIS LE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2720" y="1110" width="250" height="90" as="geometry"/></mxCell><mxCell id="mux2" value="ctl_tx_mux&#10;ADP + (AECP|ACMP)&#10;frame-atomic RR&#10;64b AXIS LE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2720" y="1230" width="250" height="90" as="geometry"/></mxCell><mxCell id="em1" value="resp 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="aecp" target="mux1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em2" value="resp 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="acmp" target="mux1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="mux1" target="mux2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em4" value="advertise" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="adp" target="mux2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="txreader" value="TX DMA reader + HW-TSO (cd_sys)&#10;&#10;descriptor ring 512 x 8 B (base/len BYTES!) ·&#10;staging 2048 beats (16 KB) · bursts 16-64 beats ·&#10;TSO header-gen (MSS segmentation in fabric,&#10;chain-csum) · reader-bound wall @100 MHz&#10;(starve 70% — prefetch/multi-outstanding = next perf lane)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="4130" y="1560" width="420" height="200" as="geometry"/></mxCell><mxCell id="cls" value="traffic_classifier (802.1Q)&#10;&#10;VLAN TPID 0x8100 parse · PCP[3b] -&gt;&#10;regen table -&gt; traffic class -&gt; queue&#10;(CSR 0x300 group: CTRL/MAP/REGEN/TCQ;&#10;identity map programmed by kl-eth)&#10;+ AVTP ethertype -&gt; class A/B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3660" y="1560" width="400" height="200" as="geometry"/></mxCell><mxCell id="queues" value="traffic_queues&#10;&#10;4 x axis_fifo, 16 KB each (DEPTH&#10;16384 bytes @ 64b) · per-queue&#10;depth/empty status -&gt; shaper&#10;gating · BRAM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3210" y="1560" width="380" height="200" as="geometry"/></mxCell><mxCell id="cbs" value="traffic_shaping_core + CBS&#10;&#10;credit_based_shaper per class:&#10;idleSlope/sendSlope (sequential slope&#10;engine, -8K LUTs, config latency 2 us,&#10;bit-exact) · credit gate + strict-prio&#10;across 4 queues (802.1Q Table 8-5)&#10;NEVER removed (user rule)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2760" y="1560" width="380" height="200" as="geometry"/></mxCell><mxCell id="ptptx" value="ptp_ts_top — TX stamp&#10;&#10;same 64-bit counter · per-frame TX&#10;timestamp -&gt; ts FIFO/window -&gt;&#10;driver (SO_TIMESTAMPING once the&#10;PHC lands)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2310" y="1560" width="360" height="200" as="geometry"/></mxCell><mxCell id="dparb" value="adp_tx_mux (datapath merge)&#10;&#10;data stream (shaped) has priority;&#10;control (ADP/AECP/ACMP) inserted in&#10;inter-frame gaps only — zero mid-&#10;frame jitter · frame-atomic&#10;64b AXIS LE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1890" y="1560" width="330" height="200" as="geometry"/></mxCell><mxCell id="ex0" value="64b AXIS LE k8 (async to cd_milan)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="txreader" target="cls"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex1" value="64b AXIS LE k8 + queue id" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="cls" target="queues"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex2" value="4 x 64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="queues" target="cbs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex3" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="cbs" target="ptptx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex4" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="ptptx" target="dparb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex5" value="control 64b LE (IFG insert)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="mux2" target="dparb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex6" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="dparb" target="mac"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex7" value="GMII 8b @125 (gtx, IOB FFs)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#d79b00;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="mac" target="phy"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex8" value="coherent AXI reads" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="txreader" target="dram"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rmon" value="ethernet_events + event_counter&#10;&#10;RMON-style counters fed by MAC event&#10;pulses (rx/tx frames, CRC err, ...) -&gt;&#10;CSR STAT0..8 @ 0x210 stride 4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="680" y="1090" width="300" height="130" as="geometry"/></mxCell><mxCell id="ev1" value="event pulses" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="mac" target="rmon"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="csr" value="milan_csr (AXI-Lite slave @ 0x9000_0000, 32b data / 16b addr)&#10;&#10;sys-side bus, CDC into cd_milan (cdc_pulse/cdc_handshake&#10;for strobes) · o_irq_csr -&gt; PLIC · full register map in the&#10;table band below · identity 0x600 group fans out to&#10;ADP + AECP + ACMP (single source of wire truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="680" y="1560" width="520" height="200" as="geometry"/></mxCell><mxCell id="ec1" value="AXI-Lite 32b @sys" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;" edge="1" parent="1" source="bus" target="csr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec2" value="identity/ctrl (CDC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="adp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec3" value="identity + status" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="aecp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec4" value="identity + 0x650" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="acmp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec5" value="0x300 classify map" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="cls"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec6" value="0x700 TCAM prog" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="tcam"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec7" value="0x2xx? counter rd" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="ptprx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="g_maps" value="address maps · geometries · frame formats&#160;&#160;(all values from the sources)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="1980" width="4560" height="440" as="geometry"/></mxCell><mxCell id="t_csr_t" value="milan_csr @ 0x9000_0000 (AXI-Lite, 64 KB window)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="70" y="2020" width="1080" height="24" as="geometry"/></mxCell><mxCell id="t_csr" value="0x000 ID=&#x27;MILN&#x27;&#160;&#160;0x004 VERSION&#160;&#160;0x008 CAP (bit12 ADP, bit13 TCAM)&#10;0x108/0x10C MAC_ALO/AHI&#160;&#160;station MAC ([7:0]=first wire byte)&#10;0x210+4n&#160;&#160;&#160;&#160;&#160;STAT0..8 RMON counters (ethernet_events)&#10;0x300 CLS_CTRL [0]use_pcp&#160;&#160;&#160;0x308 CLS_MAP prio-&gt;TC&#10;0x30C CLS_REGEN PCP regen&#160;&#160;&#160;0x310 CLS_TCQ TC-&gt;queue (2b x4)&#10;0x600 ADP_CTRL [12:8]valid_time [0]enable&#160;&#160;&#160;(reset 0x00001F00)&#10;0x604/608 ENTITY_ID lo/hi&#160;&#160;&#160;&#160;0x60C/610 MODEL_ID lo/hi&#10;0x614 ENTITY_CAPS (0x8588: AEM|CLASS_A|gPTP; no IDENTIFY bit!)&#10;0x618 TALKER {caps[31:16], sources[15:0]}&#160;&#160;0x61C LISTENER {caps,sinks}&#10;0x620 CTRL_CAPS&#160;&#160;&#160;0x624/628 gPTP GM lo/hi&#160;&#160;&#160;0x62C [7:0] gPTP domain&#10;0x630 IDX0 {identify_idx[31:16], current_cfg[15:0]}&#160;&#160;0x634 IDX1 iface&#10;0x638/63C ASSOCIATION_ID lo/hi&#10;0x640 ADP_CMD W1S [0]advertise-now(+bump) [1]depart&#160;&#160;&#160;(reads 0)&#10;0x644 ADP_STATUS RO live available_index&#10;0x648 AECP_STAT0 RO {[16]locked, [15:0]cmd_count}&#10;0x64C AECP_STAT1 RO {resp_count[31:16], current_config[15:0]}&#10;0x650 ACMP_STAT&#160;&#160;RO {resp_count[31:16], cmd_count[15:0]}&#10;0x700-0x718 TCAM: CTRL(default-pass) KLO KHI MLO MHI ACT CMD" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="70" y="2044" width="1080" height="300" as="geometry"/></mxCell><mxCell id="t_aem_t" value="AEM store (BRAM) — the entity model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1190" y="2020" width="1000" height="24" as="geometry"/></mxCell><mxCell id="t_aem" value="directory AEM_DIR_C: 5 x 64b {type[63:48], index[47:32], base[31:16], len[15:0]}&#10;&#160;&#160;0x0000 ENTITY&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;@ 0x000&#160;&#160;len 312&#160;&#160;&#160;&#160;&#160;0x0001 CONFIGURATION @ 0x138&#160;&#160;len 86&#10;&#160;&#160;0x0002 AUDIO_UNIT&#160;&#160;&#160;&#160;@ 0x18E&#160;&#160;len 156&#160;&#160;&#160;&#160;&#160;0x0006 STREAM_OUTPUT @ 0x22A&#160;&#160;len 156&#10;&#160;&#160;0x0009 AVB_INTERFACE @ 0x2C6&#160;&#160;len 98&#160;&#160;&#160;&#160;&#160;&#160;ROM total: 808 B, network byte order&#10;write-back (volatile): names ENT0@48 grp@180 CFG@316 AU@402 SO@558 AVBIF@714 (64 B&#10;&#160;&#160;each) · sampling_rate@534 (4 B, {0xBB80,0x17700,0x2EE00}=48/96/192k) · fmt@628 (8 B, 3xAAF)&#10;overlay (live CSR wins): ENTITY 4-11 eid · 12-19 model · 20-23 caps · 24-31 talker/&#10;&#160;&#160;listener · 32-35 ctrl_caps · 36-39 avail_idx · 40-47 assoc · 310-311 cfg;&#10;&#160;&#160;AVB_IF 782-787 MAC · 790-797 clock_id = {MAC[47:24],FFFE,MAC[23:0]} (= AS_PATH path[0])&#10;generation: avdecc/milan-v12-entity.json -&gt; gen_aem_store.py -&gt; gen/aecp_aem_rom.svh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1190" y="2044" width="1000" height="172" as="geometry"/></mxCell><mxCell id="t_dma_t" value="DMA geometry (kl-eth &lt;-&gt; fabric contracts)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2230" y="2020" width="1130" height="24" as="geometry"/></mxCell><mxCell id="t_dma" value="TX: descriptor ring 512 x 8 B = 4 KB (&gt;= 2 max-size frames; 8 frame slots) ·&#10;&#160;&#160;&#160;&#160;base/length registers are BYTES (devmem trap: 64-bit CSR high-word first) ·&#10;&#160;&#160;&#160;&#160;staging FIFO 2048 beats (16 KB) · AXI bursts 16-64 beats (128-512 B)&#10;RX (per queue, x2 flow-steered): 4 slots x 60 pages x 16 KB page = 960 KB ·&#10;&#160;&#160;&#160;&#160;completion queue depth 8, POP-ORDERED (wedge-invariant by construction;&#10;&#160;&#160;&#160;&#160;driver mslot60 &lt;-&gt; gateware build_r2slots STRICT pairing) ·&#10;&#160;&#160;&#160;&#160;header-split v3: page fill length in w0[31:16] -&gt; page &lt;= 32 KB; 16 KB chosen&#10;&#160;&#160;&#160;&#160;(--hs-page-bytes 16384 &lt;-&gt; insmod hs_pgsz=16384 STRICT pairing; 256-desc ring&#10;&#160;&#160;&#160;&#160;FORBIDDEN on &lt;=hsq5 gateware — BD-ring lap collapse) ·&#10;&#160;&#160;&#160;&#160;RSC coalescer: RING_RSC_TOUT in 100 MHz ticks (ethtool -C rx-usecs; default 250 us)&#10;descriptor: {addr, len, flags, RX/TX timestamp window (dts kl,dma-ts @ 0x3100)}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="2230" y="2044" width="1130" height="188" as="geometry"/></mxCell><mxCell id="t_frames_t" value="control-plane frame formats (wire offsets)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="3400" y="2020" width="1150" height="24" as="geometry"/></mxCell><mxCell id="t_frames" value="ADPDU&#160;&#160;&#160;82 B&#160;&#160;subtype 0xFA · CDL 0x38(56) · entity_id@18 · caps@34 · avail_idx@50 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;gm@54 · domain@62 · cfg@64 · identify@66 · iface@68 · assoc@70&#10;AECPDU&#160;&#160;var.&#160;&#160;subtype 0xFB · CDL=frame-26 (base 12; counts after target_eid@18) ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;controller@26 · seq@34 · u/cmd@36 · payload@38 (little lane on wire;&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;parser chain internally BIG lane) · runt pad to 60, CDL unpadded&#10;ACMPDU&#160;&#160;70 B&#160;&#160;subtype 0xFC · CDL 44 · stream_id@18 · controller@26 · talker@34 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;listener@42 · uids@50/52 · dmac@54 · count@60 · seq@62 · flags@64 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;vlan@66 · rsvd@68&#160;&#160;(responses multicast, like commands)&#10;multicast 91:E0:F0:01:00:00 (ADP+ACMP) · AVTP ethertype 0x22F0 · min wire frame 60 B&#10;TCAM default entries: station MAC + AVDECC multicast (ADP discovery reaches the taps)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="3400" y="2044" width="1150" height="172" as="geometry"/></mxCell><mxCell id="g_state" value="build + verification state (2026-07-12)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="2460" width="4560" height="400" as="geometry"/></mxCell><mxCell id="t_builds_t" value="gateware builds" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="70" y="2500" width="1400" height="24" as="geometry"/></mxCell><mxCell id="t_builds" value="AX7101 keeper: build_ax7101_eto_aecp7 (WNS +0.091) — la_avdecc AECP-clean;&#10;&#160;&#160;acmp1 sweep (this ACMP responder) IN FLIGHT: expect Milan=1 CLEAN&#10;cfg: vexii x2 · 100 MHz sys + 100 MHz milan · rx-queues 2 · hs 16 KB ·&#10;&#160;&#160;QSPI flashboot · gtx-tx-invert · timing-opt + floorplan · 3-seed sweeps,&#10;&#160;&#160;32 threads/instance (96 aborts P&amp;R), keep best WNS &gt;= 0&#10;Arty keeper: build_arty_v7 (WNS +0.018) — sys 83.333 / milan 50 / MII 100M" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="70" y="2524" width="1400" height="108" as="geometry"/></mxCell><mxCell id="t_verif_t" value="verification ladder" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1510" y="2500" width="1500" height="24" as="geometry"/></mxCell><mxCell id="t_verif" value="Verilator: aecp 68/68 · acmp 41/41 · adp 121/121 · milan_dp 26/26 (incl. full-datapath&#10;&#160;&#160;ACMP exchange) · classifier/queues/cbs/ptp/tcam harnesses · lint 11/11&#10;co-sim: tsn-gen &lt;-&gt; real RTL over AxiStreamBeat socket 42/42 (CDL oracle: spec, NOT tsn-gen)&#10;portability: Yosys+sv2v generic synth 20/20 (KL_aecp_top 33.6K cells, acmp 8.8K) — device-&#10;&#160;&#160;independent (ECP5 target proven); sv2v v0.0.13 traps documented (interfaces, $error)&#10;silicon: controller 26/26 (31 with ACMP staged) · la_avdecc: ONLINE, IEEE17221=1, zero AEM&#10;&#160;&#160;complaints; Milan=1 gated by ACMP GET_TX_STATE (this build)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1510" y="2524" width="1500" height="124" as="geometry"/></mxCell><mxCell id="t_perf_t" value="performance truth (HW counters, not models)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="3050" y="2500" width="1500" height="24" as="geometry"/></mxCell><mxCell id="t_perf" value="measured ceilings (100 MHz): TX 186 Mbit (TSO zc; reader-bound, starve 70%) · RX 223 (-P2&#10;&#160;&#160;steered) / 209 single (RSC) · two-node ADP through the AVB switch TX 83 / RX 94 (100M port)&#10;latency: single-port ceiling = memory (1424 ns/miss: 50% TLB + 50% DRAM) · rx-usecs-low +32%&#10;next perf lanes: TX reader prefetch/multi-outstanding · AF_XDP ZC (RX&gt;500) · 1-hart &lt;70% slices&#10;gPTP: HW timestamps + linuxptp present; kl-eth PHC = the gate (HW_SW_SPLIT next item)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="3050" y="2524" width="1500" height="92" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>