<mxfile host="app.diagrams.net"><diagram name="milan-system-map"><mxGraphModel dx="2000" dy="1400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="5560" pageHeight="3170" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="MILAN AVB NIC on VexiiRiscv SoC — THE FULL SYSTEM MAP&#160;&#160;·&#160;&#160;AX7101 xc7a100t (board of record; Arty deltas noted)&#160;&#160;·&#160;&#160;every wire: bus width&#160;&#160;·&#160;&#160;every register file / BRAM: own block with size + address&#160;&#160;·&#160;&#160;colours = clock domains&#160;&#160;·&#160;&#160;2026-07-12" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#333;fontSize=20;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="16" width="5480" height="44" as="geometry"/></mxCell><mxCell id="g_leg" value="legend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="76" width="1180" height="104" as="geometry"/></mxCell><mxCell id="lg1" value="sys @ 100 MHz (cd_sys)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="106" width="190" height="26" as="geometry"/></mxCell><mxCell id="lg2" value="milan datapath @ 100 MHz (cd_milan)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="262" y="106" width="214" height="26" as="geometry"/></mxCell><mxCell id="lg3" value="eth_rx / eth_tx @ 125 MHz (LiteEth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="488" y="106" width="214" height="26" as="geometry"/></mxCell><mxCell id="lg4" value="off-chip" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="714" y="106" width="112" height="26" as="geometry"/></mxCell><mxCell id="lg5" value="register file / BRAM / DRAM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="838" y="106" width="190" height="26" as="geometry"/></mxCell><mxCell id="lg6" value="arbiter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1040" y="106" width="90" height="26" as="geometry"/></mxCell><mxCell id="lg7" value="lanes:&#160;&#160;LE = little (tdata[7:0] = first wire byte, Forencich/MAC)&#160;&#160;&#160;BE = big (tdata[63:56] first — AECP parser chain only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9d6;strokeColor=#b3a100;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="60" y="142" width="1140" height="26" as="geometry"/></mxCell><mxCell id="g_clk" value="clock tree (S7 PLL, from 200 MHz osc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="1260" y="76" width="1180" height="104" as="geometry"/></mxCell><mxCell id="t_clk" value="osc 200 -&gt; PLL: cd_sys 100 · cd_sys4x 400 + dqs 90deg (DDR3-800) · cd_idelay 200 · cd_milan 100 (own domain; Arty: 50)&#10;LiteEth: eth_rx = PHY rx_clk 125 · eth_tx = gtx 125 (tx_clk_invert; GMII launch FFs IOB-packed — silicon rule)&#10;crossings: AXI-Lite CSR sys&lt;-&gt;milan (bus CDC) · MAC async FIFOs eth&lt;-&gt;milan · DMA in sys, AXIS FIFOs to milan" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1280" y="108" width="1140" height="60" as="geometry"/></mxCell><mxCell id="g_soc" value="SoC / softcore&#160;&#160;(LiteX, cd_sys 100 MHz)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="210" width="3060" height="600" as="geometry"/></mxCell><mxCell id="cpu" value="VexiiRiscv x2 harts (RV64IMA)&#10;&#10;L1 caches + L2 64 KB shared&#10;(l2-bytes 65536)&#10;lsu-l1-refill-count=8 · prefetch rpt&#10;l2-down-pending=8 · general-slots=16&#10;(1-hart decision pending: 58% LUTs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="260" width="330" height="160" as="geometry"/></mxCell><mxCell id="plic" value="PLIC + CLINT&#10;IRQs: milan_csr o_irq_csr · kl-eth DMA&#10;per-queue · UART · timer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="460" width="330" height="60" as="geometry"/></mxCell><mxCell id="bus" value="LiteX interconnect&#10;&#10;Wishbone/AXI&#10;CSR bus 32b&#10;+ coherent DMA&#10;port into the L2&#10;(--coherent-dma)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="520" y="260" width="210" height="260" as="geometry"/></mxCell><mxCell id="dramc" value="LiteDRAM controller&#10;A7DDRPHY (sys4x 400 + DQS 90°,&#10;200 MHz IDELAYCTRL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="850" y="260" width="280" height="120" as="geometry"/></mxCell><mxCell id="ddr" value="DDR3 SDRAM (off-chip)&#10;MT41K256M16 x16 · 512 MB&#10;@ 0x4000_0000 (CPU view)&#10;kernel@+0 · dtb@0x40EF_0000 ·&#10;opensbi@0x40F0_0000 · initrd@0x4100_0000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1290" y="260" width="310" height="130" as="geometry"/></mxCell><mxCell id="txring" value="TX descriptor ring (in DRAM)&#10;512 x 8 B = 4 KB (&gt;= 2 max frames,&#10;8 frame slots) · driver-allocated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1290" y="430" width="310" height="70" as="geometry"/></mxCell><mxCell id="rxrings" value="RX rings (in DRAM, per queue x2)&#10;4 slots x 60 pages x 16 KB = 960 KB&#10;+ completion queue 8 entries,&#10;POP-ORDERED (mslot60) · driver-alloc" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1290" y="520" width="310" height="90" as="geometry"/></mxCell><mxCell id="uart" value="UART 115200&#10;(litex_term)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="850" y="420" width="140" height="50" as="geometry"/></mxCell><mxCell id="jtag" value="JTAG (openFPGALoader&#10;ft232 210512180081)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1010" y="420" width="150" height="50" as="geometry"/></mxCell><mxCell id="qspi" value="QSPI flash N25Q128 16 MB (off-chip)&#10;flashboot slots: kernel@0 (8.5 MiB) ·&#10;opensbi@0x88_0000 (512 KiB) ·&#10;dtb@0x90_0000 · rootfs@0x94_0000 (6.75 MiB)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="850" y="490" width="310" height="80" as="geometry"/></mxCell><mxCell id="dmaeng" value="kl-eth DMA engines (fabric, cd_sys, coherent port)&#10;&#10;TX reader: fetches the 512x8B ring (base/length in BYTES — trap!),&#10;AXI bursts 16-64 beats x 64b (128-512 B) · + HW-TSO header generator&#10;(MSS segmentation, chain-csum; validated TX 143-&gt;186 zc)&#10;&#10;RX writer: RSC TCP coalescer (RING_RSC_TOUT, 100 MHz ticks, default&#10;250 us) · header-split v3 (fill length in w0[31:16], page &lt;= 32 KB) ·&#10;4-slot writer + pop-ordered CQ · 2-queue flow steer (4-tuple hash;&#10;hash_sel=1 forces q0 — set BEFORE TCP runs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="560" width="660" height="230" as="geometry"/></mxCell><mxCell id="stag" value="TX staging FIFO&#10;BRAM 2048 beats x 64b = 16 KB" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="790" y="590" width="240" height="70" as="geometry"/></mxCell><mxCell id="csrjson" value="LiteX CSR block @ 0xf000_0000&#10;(ring ctl, RSC tout, steer/hash,&#10;IRQ status) — offsets BUILD-&#10;DEPENDENT: read csr.json!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="790" y="690" width="240" height="100" as="geometry"/></mxCell><mxCell id="kleth" value="kl-eth Linux driver&#160;&#160;(kl,dma-ether · silicon; MODULE_VERSION gates identity)&#10;&#10;• 2 RX queues (flow-steered) x threaded NAPI · budget/gro knobs&#10;• RSC ON by default @250 us (ethtool -C rx-usecs retunes live; rsc_clk_mhz=100)&#10;• header-split hs_pgsz=16384 &lt;-&gt; gateware --hs-page-bytes 16384 (STRICT pairing)&#10;• 4-slot RX + pop-ordered CQ (wedge-free by construction) · 60 KB order-4 buffers&#10;• HW-TSO on TX · chain-csum · ethtool -C ack-merge tout 512 us&#10;• identity provisioning once/boot: devmem 0x9000_0600 group (aecp_csr_setup.sh)&#10;• NEXT: PHC /dev/ptpN + SO_TIMESTAMPING (gPTP gate — HW_SW_SPLIT.md)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1690" y="260" width="690" height="250" as="geometry"/></mxCell><mxCell id="sw2" value="userspace: linuxptp ptp4l+phc2sys (present, unvalidated until PHC) · PipeWire module-avb (future media:&#10;AAF frames -&gt; kl-eth -&gt; CBS class-A queue) · la_avdecc / Hive / milan_controller.py validate from the peer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1690" y="540" width="690" height="70" as="geometry"/></mxCell><mxCell id="irqn" value="IRQ fan-in&#10;per-queue RX complete + TX done +&#10;milan_csr o_irq_csr -&gt; PLIC&#10;(rx-usecs-low moderation: +32%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRig