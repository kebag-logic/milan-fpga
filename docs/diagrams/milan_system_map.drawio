l=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="850" width="5480" height="1340" as="geometry"/></mxCell><mxCell id="phy" value="RTL8211E PHY&#10;(GMII-strapped,&#10;8-bit SDR — an&#10;RGMII read corrupts&#10;every byte:&#10;hardware-confirmed)&#10;&#10;1000BASE-T&#10;to the AVB switch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="70" y="950" width="190" height="620" as="geometry"/></mxCell><mxCell id="mac" value="MilanMAC&#160;&#160;(LiteEth)&#10;&#10;LiteEthPHYGMII (gtx 125, tx_clk_invert,&#10;launch FFs IOB-packed — placement rule)&#10;+ LiteEthMACCore: preamble/SFD, CRC32,&#10;padding, width conversion 8b&lt;-&gt;64b,&#10;dual-clock stream FIFOs eth&lt;-&gt;cd_milan&#10;+ stream&lt;-&gt;AXIS adapter:&#10;last_be (one-hot) &lt;-&gt; tkeep (mask)&#10;(the M-A3 no-frame-on-wire root cause)&#10;&#10;Arty: LiteEthPHYMII (DP83848, 100M,&#10;is_1g=0 -&gt; CBS slope wiring pending)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="330" y="950" width="330" height="620" as="geometry"/></mxCell><mxCell id="ptprx" value="ptp_ts_top — RX stamp&#10;&#10;per-frame RX timestamp captured&#10;into the DMA descriptor ts window&#10;(dts kl,dma-ts @ +0x3100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="820" y="950" width="280" height="130" as="geometry"/></mxCell><mxCell id="ptpregs" value="PTP counter + CSR regs&#10;64b counter FF (cd_milan) ·&#10;CSR 0x500-0x544: CTRL/INCR/ADJ/&#10;TW lo·hi/OF lo·hi/CMD/TR lo·hi/LATs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="820" y="1130" width="280" height="90" as="geometry"/></mxCell><mxCell id="tcam" value="rx_mac_filter (TCAM logic)&#10;&#10;ternary match on dst MAC ·&#10;default-pass CSR bit · miss+no-&#10;default -&gt; drop (never backpressures)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1340" y="950" width="300" height="130" as="geometry"/></mxCell><mxCell id="tcamregs" value="TCAM entry array&#10;16 x {key 48b + mask 48b + action 8b}&#10;= 1664 b FF · programmed @ 0x700-&#10;0x718 (CTRL/KLO/KHI/MLO/MHI/ACT/CMD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1340" y="1130" width="300" height="90" as="geometry"/></mxCell><mxCell id="rxnode" value="rx_axis_to_dma&#10;(the tap point — post-filter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1900" y="985" width="260" height="60" as="geometry"/></mxCell><mxCell id="rsc" value="RX DMA front (cd_sys side)&#10;&#10;RSC coalescer · header-split v3&#10;(16 KB pages) · 4-slot writer +&#10;CQ(8) pop-ordered · 2-queue steer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2440" y="950" width="340" height="130" as="geometry"/></mxCell><mxCell id="er0" value="GMII 8b @ 125 (rx_clk)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#d79b00;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="phy" target="mac"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er1" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="mac" target="ptprx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er2" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ptprx" target="tcam"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er3" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="tcam" target="rxnode"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er4" value="64b AXIS LE k8 (async FIFO -&gt; cd_sys)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rxnode" target="rsc"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er5" value="coherent AXI 64b (via L2)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="rsc" target="rxrings"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er6" value="ts 64b · CSR 32b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="ptprx" target="ptpregs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="er7" value="16 x key/mask 48b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="tcam" target="tcamregs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="rmon" value="ethernet_events (logic)&#10;RMON-style event capture fed by MAC&#10;pulses (rx/tx frames, CRC err, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="330" y="1640" width="330" height="110" as="geometry"/></mxCell><mxCell id="rmonregs" value="event counters: 9 x 32b FF&#10;RO @ 0x210-0x230 (STAT0..8, stride 4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="330" y="1790" width="330" height="60" as="geometry"/></mxCell><mxCell id="ev1" value="event pulses 1b each" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="mac" target="rmon"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ev2" value="9 x 32b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="rmon" target="rmonregs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="aecp" value="KL_aecp_top — AECP/AEM entity (Milan v1.2 §5.4, la_avdecc-clean)&#10;&#10;ingress MONITOR tap (registered, never backpressures)&#10;-&gt; validator -&gt; parser [internal links 64b AXIS BE] -&gt; l0&#10;(LOCK 60 s / ACQUIRE=NOT_SUPPORTED) -&gt; response_builder&#10;(segment engine NONE/ECHO/STORE/CONST x4 · CDL = frame-26)&#10;commands: READ_DESCRIPTOR · names · config · sampling-rate ·&#10;stream-format · STREAM_INFO(56B) · AVB_INFO · COUNTERS(136B,&#10;full-size on errors) · AS_PATH · MVU GET_MILAN_INFO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1500" y="1330" width="430" height="270" as="geometry"/></mxCell><mxCell id="aecpbuf" value="ingress frame buf&#10;128 B LUTRAM&#10;(MAX_FRAME_BYTES)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1500" y="1640" width="200" height="70" as="geometry"/></mxCell><mxCell id="aecpwork" value="builder working set&#10;buf_r 64 B FF (capture) ·&#10;const_q 64 B FF (payloads)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1720" y="1640" width="210" height="70" as="geometry"/></mxCell><mxCell id="aemstore" value="AEM store — BRAM 808 B (byte port 8b, addr 16b, 1-cycle)&#10;directory 5 x 64b FF {type,idx,base,len}&#10;ENTITY@0x000/312 · CONFIG@0x138/86 · AUDIO@0x18E/156 ·&#10;STREAM_OUT@0x22A/156 · AVB_IF@0x2C6/98&#10;wb: names@48/180/316/402/558/714 · rate@534 · fmt@628" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1990" y="1640" width="400" height="110" as="geometry"/></mxCell><mxCell id="acmp" value="KL_acmp_responder — ACMP stateless talker (§5.5)&#10;&#10;same registered-tap pattern · 70 B ACMPDU (CDL 44)&#10;GET_TX_STATE -&gt; SUCCESS, count=0, stream fields&#10;zeroed, probe flags cleared (uid!=0 -&gt;&#10;TALKER_UNKNOWN_ID) · GET_TX_CONNECTION -&gt;&#10;NOT_SUPPORTED (Milan 5.5.4.4) · CONNECT/&#10;DISCONNECT_TX -&gt; NOT_SUPPORTED until the softcore&#10;policy mailbox (HW answers / SW decides)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2480" y="1330" width="380" height="270" as="geometry"/></mxCell><mxCell id="acmpbuf" value="frame buf&#10;72 B LUTRAM (9 beats)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2480" y="1640" width="200" height="70" as="geometry"/></mxCell><mxCell id="adp" value="adp_advertiser — ADP (§6.2)&#10;&#10;82 B ADPDU (CDL 0x38) · periodic every&#10;valid_time s (vt=31 -&gt; validity 62 s) ·&#10;AVAILABLE / DEPARTING / discover response ·&#10;available_index +1 on EVERY ADPDU&#10;(la_avdecc strict rule) · priority: depart &gt;&#10;link_up &gt; info/gm change &gt; discover &gt; timer ·&#10;enable-edge with link up == link_up&#10;(boot-order fix) · identity: 0x600 CSR group&#10;(shared with AEM overlay — cannot diverge)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2940" y="1330" width="370" height="270" as="geometry"/></mxCell><mxCell id="adpidx" value="available_index 32b FF&#10;RO @ 0x644 (live counter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2940" y="1640" width="250" height="60" as="geometry"/></mxCell><mxCell id="mux1" value="aecp_acmp_mux&#10;(adp_tx_arbiter)&#10;frame-atomic RR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3440" y="1360" width="250" height="90" as="geometry"/></mxCell><mxCell id="mux2" value="ctl_tx_mux&#10;ADP + (AECP|ACMP)&#10;frame-atomic RR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3440" y="1500" width="250" height="90" as="geometry"/></mxCell><mxCell id="et1" value="tap (copy) 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="rxnode" target="aecp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et2" value="tap (copy) 64b LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="rxnode" target="acmp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et3" value="ENTITY_DISCOVER pulse 1b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="aecp" target="adp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et4" value="8b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="aecp" target="aecpbuf"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et5" value="byte port 8b · addr 16b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="aecp" target="aemstore"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et6" value="8b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="acmp" target="acmpbuf"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="et7" value="32b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="adp" target="adpidx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em1" value="resp 64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="aecp" target="mux1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em2" value="resp 64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="acmp" target="mux1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em3" value="64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="mux1" target="mux2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="em4" value="advertise 64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="adp" target="mux2"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="dparb" value="adp_tx_mux (datapath merge)&#10;&#10;data stream (shaped) has priority;&#10;control (ADP/AECP/ACMP) inserted in&#10;inter-frame gaps only — zero mid-&#10;frame jitter · frame-atomic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="1500" y="1910" width="330" height="190" as="geometry"/></mxCell><mxCell id="ptptx" value="ptp_ts_top — TX stamp&#10;&#10;same 64b counter · per-frame TX&#10;timestamp -&gt; ts window -&gt; driver&#10;(SO_TIMESTAMPING once the PHC lands)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2080" y="1910" width="340" height="190" as="geometry"/></mxCell><mxCell id="cbs" value="traffic_shaping_core + CBS (logic)&#10;&#10;credit gate + strict-priority across 4&#10;queues (802.1Q Table 8-5) · sequential&#10;slope engine (-8K LUTs, bit-exact,&#10;config latency 2 us) · NEVER removed&#10;(user rule)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2670" y="1910" width="380" height="190" as="geometry"/></mxCell><mxCell id="cbsregs" value="CBS register file (per queue x4)&#10;idleSlope 32b + credit/limit regs · @ 0x400 stride 0x20&#10;reset idleSlopes {300,200,150,100} Mb/s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="2670" y="2140" width="380" height="70" as="geometry"/></mxCell><mxCell id="queues" value="traffic_queues — BRAM&#10;&#10;4 x axis_fifo, 16 KB each (DEPTH 16384&#10;bytes @ 64b) = 64 KB total · per-queue&#10;depth/empty status -&gt; shaper gating&#10;(no bus address — fabric-internal)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3300" y="1910" width="380" height="190" as="geometry"/></mxCell><mxCell id="cls" value="traffic_classifier (802.1Q logic)&#10;&#10;VLAN TPID 0x8100 parse · PCP[3b] -&gt;&#10;regen -&gt; traffic class -&gt; queue select&#10;+ AVTP ethertype 0x22F0 -&gt; class A/B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3930" y="1910" width="400" height="190" as="geometry"/></mxCell><mxCell id="clsregs" value="classifier map registers (FF)&#10;PCP regen 8x3b · prio-&gt;TC 8x2b · TC-&gt;queue 4x2b&#10;@ 0x300 CTRL · 0x308 MAP · 0x30C REGEN · 0x310 TCQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="3930" y="2140" width="400" height="70" as="geometry"/></mxCell><mxCell id="txreader" value="TX DMA reader + HW-TSO (cd_sys)&#10;&#10;descriptor fetch from the 512x8B ring ·&#10;TSO header-gen (MSS segmentation,&#10;chain-csum) · reader-bound wall @100 MHz&#10;(starve 70% — prefetch = next perf lane)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="4580" y="1910" width="420" height="190" as="geometry"/></mxCell><mxCell id="ex0" value="64b AXIS LE k8 (async FIFO -&gt; cd_milan)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="txreader" target="cls"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex1" value="64b AXIS LE k8 + queue 2b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cls" target="queues"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex2" value="4 x 64b AXIS LE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="queues" target="cbs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex3" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="cbs" target="ptptx"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex4" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="ptptx" target="dparb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex5" value="control 64b AXIS LE (IFG insert)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="mux2" target="dparb"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex6" value="64b AXIS LE k8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#6c8ebf;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="dparb" target="mac"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex7" value="GMII 8b @ 125 (gtx, IOB FFs)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#d79b00;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="mac" target="phy"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex8" value="coherent AXI reads 64b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="txreader" target="txring"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex9" value="4 x 32b slope" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="cbs" target="cbsregs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex10" value="map bits" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="cls" target="clsregs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ex11" value="depth status x4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="queues" target="cbs"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="csr" value="milan_csr — REGISTER FILE (~46 x 32b FF) + AXI-Lite slave&#10;@ 0x9000_0000, 64 KB window (data 32b, addr 16b), cd_sys side,&#10;CDC into cd_milan (cdc_pulse/cdc_handshake for strobes)&#10;groups: ID/VER/CAP@0x000 · MAC@0x108 · STATS@0x210 · CLS@0x300 ·&#10;CBS@0x400 · PTP@0x500 · ADP identity@0x600 · AECP@0x648 ·&#10;ACMP@0x650 · TCAM@0x700 (full map in the table below)&#10;o_irq_csr -&gt; PLIC · identity fans out to ADP+AECP+ACMP:&#10;one source of wire truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;" vertex="1" parent="1"><mxGeometry x="620" y="1940" width="560" height="190" as="geometry"/></mxCell><mxCell id="ec1" value="AXI-Lite 32b @ sys" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="bus" target="csr"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec2" value="identity fields (CDC)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="adp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec3" value="identity 4 x 64b + status 32b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="aecp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="ec4" value="identity + counters 2 x 16b" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;endFill=1;strokeColor=#333333;strokeWidth=1.6;fontSize=11;labelBackgroundColor=#ffffff;dashed=1;endArrow=open;" edge="1" parent="1" source="csr" target="acmp"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="g_maps" value="address maps · geometries · frame formats&#160;&#160;(all values from the sources)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="2240" width="5480" height="480" as="geometry"/></mxCell><mxCell id="t_csr_t" value="milan_csr @ 0x9000_0000 (AXI-Lite, 64 KB window)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="70" y="2280" width="1120" height="24" as="geometry"/></mxCell><mxCell id="t_csr" value="0x000 ID=&#x27;MILN&#x27;&#160;&#160;&#160;0x004 VERSION&#160;&#160;&#160;0x008 CAP (bit12 ADP, bit13 TCAM)&#10;0x108/0x10C MAC_ALO/AHI ([7:0] = first wire byte)&#10;0x210+4n&#160;&#160;&#160;&#160;&#160;STAT0..8 RMON counters (RO)&#10;0x300 CLS_CTRL [0]use_pcp · 0x308 MAP · 0x30C REGEN · 0x310 TCQ&#10;0x400+q*0x20 CBS queue q: idleSlope/credit regs (reset 300/200/150/100 Mb/s)&#10;0x500-0x544&#160;&#160;PTP: CTRL INCR ADJ TWLO/HI OFLO/HI CMD TRLO/HI ILAT ELAT&#10;0x600 ADP_CTRL [12:8]valid_time [0]enable&#160;&#160;(reset 0x00001F00)&#10;0x604/608 ENTITY_ID · 0x60C/610 MODEL_ID · 0x614 CAPS (0x8588, no&#10;&#160;&#160;IDENTIFY bit — no CONTROL descriptor!) · 0x618 TALKER {caps,sources}&#10;0x61C LISTENER {caps,sinks} · 0x620 CTRL_CAPS · 0x624/628 gPTP GM&#10;0x62C [7:0] domain · 0x630 IDX0 {identify,current_cfg} · 0x634 IDX1 iface&#10;0x638/63C ASSOCIATION_ID · 0x640 ADP_CMD W1S [0]advertise [1]depart&#10;0x644 ADP_STATUS RO avail_idx · 0x648 AECP {[16]locked,[15:0]cmds}&#10;0x64C AECP {resps,cfg} · 0x650 ACMP {resps,cmds} · 0x700-0x718 TCAM" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="70" y="2304" width="1120" height="236" as="geometry"/></mxCell><mxCell id="t_aem_t" value="AEM store BRAM — the entity model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1230" y="2280" width="1030" height="24" as="geometry"/></mxCell><mxCell id="t_aem" value="directory: 5 x 64b {type[63:48], index[47:32], base[31:16], len[15:0]}&#10;&#160;&#160;0x0000 ENTITY&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;@ 0x000&#160;&#160;len 312&#160;&#160;&#160;&#160;0x0001 CONFIGURATION @ 0x138&#160;&#160;len 86&#10;&#160;&#160;0x0002 AUDIO_UNIT&#160;&#160;&#160;&#160;@ 0x18E&#160;&#160;len 156&#160;&#160;&#160;&#160;0x0006 STREAM_OUTPUT @ 0x22A&#160;&#160;len 156&#10;&#160;&#160;0x0009 AVB_INTERFACE @ 0x2C6&#160;&#160;len 98&#160;&#160;&#160;&#160;&#160;ROM total 808 B, network byte order&#10;write-back (volatile): names ENT0@48 grp@180 CFG@316 AU@402 SO@558 AVBIF@714&#10;&#160;&#160;(64 B each) · rate@534 (4 B: 0xBB80/0x17700/0x2EE00 = 48/96/192 k) · fmt@628 (8 B)&#10;overlay (live CSR wins): ENTITY 4-11 eid · 12-19 model · 20-23 caps · 24-31 talker/&#10;&#160;&#160;listener · 32-35 ctrl · 36-39 avail_idx · 40-47 assoc · 310-311 cfg;&#160;&#160;AVB_IF&#10;&#160;&#160;782-787 MAC · 790-797 clock_id {MAC[47:24],FFFE,MAC[23:0]} (= AS_PATH path[0])&#10;generation: avdecc/milan-v12-entity.json -&gt; gen_aem_store.py -&gt; gen/aecp_aem_rom.svh" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1230" y="2304" width="1030" height="172" as="geometry"/></mxCell><mxCell id="t_dma_t" value="DMA geometry (kl-eth &lt;-&gt; fabric contracts)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="2300" y="2280" width="1150" height="24" as="geometry"/></mxCell><mxCell id="t_dma" value="TX: ring 512 x 8 B = 4 KB (&gt;= 2 max frames; 8 frame slots) · base/length in BYTES&#10;&#160;&#160;&#160;&#160;(devmem trap: 64-bit CSR high word first) · staging 2048 x 64b (16 KB BRAM) ·&#10;&#160;&#160;&#160;&#160;AXI bursts 16-64 beats x 64b (128-512 B)&#10;RX (per queue x2): 4 slots x 60 pages x 16 KB = 960 KB · CQ depth 8 POP-ORDERED&#10;&#160;&#160;&#160;&#160;(driver mslot60 &lt;-&gt; gateware build_r2slots STRICT pairing) · header-split v3:&#10;&#160;&#160;&#160;&#160;fill length in w0[31:16] -&gt; page &lt;= 32 KB; 16 KB chosen (--hs-page-bytes 16384&#10;&#160;&#160;&#160;&#160;&lt;-&gt; insmod hs_pgsz=16384 STRICT; 256-desc ring FORBIDDEN on &lt;=hsq5 gateware)&#10;RSC: RING_RSC_TOUT in 100 MHz ticks (ethtool -C rx-usecs; default 250 us)&#10;descriptor: {addr, len, flags, RX/TX timestamp window (dts kl,dma-ts @ +0x3100)}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="2300" y="2304" width="1150" height="156" as="geometry"/></mxCell><mxCell id="t_frames_t" value="control-plane frame formats (wire offsets)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="3510" y="2280" width="1180" height="24" as="geometry"/></mxCell><mxCell id="t_frames" value="ADPDU&#160;&#160;&#160;82 B&#160;&#160;subtype 0xFA · CDL 0x38(56) · entity_id@18 · caps@34 · avail_idx@50 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;gm@54 · domain@62 · cfg@64 · identify@66 · iface@68 · assoc@70&#10;AECPDU&#160;&#160;var.&#160;&#160;subtype 0xFB · CDL = frame-26 (base 12; counts after target_eid@18) ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;controller@26 · seq@34 · u/cmd@36 · payload@38 · LE on wire (parser&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;chain internally BE) · runt pad to 60, CDL counts unpadded&#10;ACMPDU&#160;&#160;70 B&#160;&#160;subtype 0xFC · CDL 44 · stream_id@18 · controller@26 · talker@34 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;listener@42 · uids@50/52 · dmac@54 · count@60 · seq@62 · flags@64 ·&#10;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;vlan@66 · rsvd@68&#160;&#160;(responses multicast, like commands)&#10;multicast 91:E0:F0:01:00:00 (ADP+ACMP) · AVTP ethertype 0x22F0 · min wire frame 60 B" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="3510" y="2304" width="1180" height="156" as="geometry"/></mxCell><mxCell id="g_state" value="build + verification state (2026-07-12)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;dashed=1;verticalAlign=top;align=left;fontSize=15;fontStyle=1;spacingLeft=8;spacingTop=4;" vertex="1" parent="1"><mxGeometry x="40" y="2760" width="5480" height="380" as="geometry"/></mxCell><mxCell id="t_builds_t" value="gateware builds" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="70" y="2800" width="1400" height="24" as="geometry"/></mxCell><mxCell id="t_builds" value="AX7101 keeper: build_ax7101_eto_aecp7 (WNS +0.091) — la_avdecc AECP-clean;&#10;&#160;&#160;acmp2 sweep (ACMP responder) IN FLIGHT: expect Milan=1 CLEAN&#10;cfg: vexii x2 · 100 MHz sys + 100 MHz milan · rx-queues 2 · hs 16 KB ·&#10;&#160;&#160;QSPI flashboot · gtx-tx-invert · timing-opt + floorplan · 3-seed sweeps,&#10;&#160;&#160;32 threads/instance (96 aborts P&amp;R), keep best WNS &gt;= 0&#10;Arty keeper: build_arty_v7 (WNS +0.018) — sys 83.333 / milan 50 / MII 100M" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="70" y="2824" width="1400" height="108" as="geometry"/></mxCell><mxCell id="t_verif_t" value="verification ladder" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1510" y="2800" width="1500" height="24" as="geometry"/></mxCell><mxCell id="t_verif" value="Verilator: aecp 68/68 · acmp 41/41 · adp 121/121 · milan_dp 26/26 (incl. full-datapath&#10;&#160;&#160;ACMP exchange) · classifier/queues/cbs/ptp/tcam harnesses · lint 11/11&#10;co-sim: tsn-gen &lt;-&gt; real RTL over AxiStreamBeat socket 42/42 (CDL oracle: spec, NOT tsn-gen)&#10;portability: Yosys+sv2v generic synth 20/20 (KL_aecp_top 33.6K cells, acmp 8.8K) —&#10;&#160;&#160;device-independent (ECP5 proven); sv2v v0.0.13 traps documented&#10;silicon: controller 26/26 (31 with ACMP staged) · la_avdecc: ONLINE, IEEE17221=1, zero AEM&#10;&#160;&#160;complaints; Milan=1 gated by ACMP GET_TX_STATE (the acmp2 build)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="1510" y="2824" width="1500" height="124" as="geometry"/></mxCell><mxCell id="t_perf_t" value="performance truth (HW counters, not models)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8e8e8;strokeColor=#666666;fontSize=12;verticalAlign=middle;align=center;spacingLeft=6;spacingRight=6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="3050" y="2800" width="1500" height="24" as="geometry"/></mxCell><mxCell id="t_perf" value="measured ceilings (100 MHz): TX 186 Mbit (TSO zc; reader-bound, starve 70%) · RX 223 (-P2&#10;&#160;&#160;steered) / 209 single (RSC) · two-node ADP through the AVB switch TX 83 / RX 94 (100M port)&#10;latency: single-port ceiling = memory (1424 ns/miss: 50% TLB + 50% DRAM) · rx-usecs-low +32%&#10;next perf lanes: TX reader prefetch/multi-outstanding · AF_XDP ZC (RX&gt;500) · 1-hart &lt;70% slices&#10;gPTP: HW timestamps + linuxptp present; kl-eth PHC = the gate (HW_SW_SPLIT next item)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;verticalAlign=middle;align=left;spacingLeft=6;spacingRight=6;fontFamily=Courier New;" vertex="1" parent="1"><mxGeometry x="3050" y="2824" width="1500" height="92" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>