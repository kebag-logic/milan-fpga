<mxfile host="app.diagrams.net" agent="milan-fpga docs" version="24.0">
  <diagram id="rx-tuning-map" name="RX datapath — performance tuning map (2026-07-11)">
    <mxGraphModel dx="2000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ================= TITLE ================= -->
        <mxCell id="title" value="&lt;b&gt;Milan NIC RX datapath — every tuning point, current value, measured effect (state: hsq10/12 era, 2026-07-11)&lt;/b&gt;&lt;br&gt;Records: TCP-socket P4 381 / 374@120s (keeper hsq10+hsplit12) · no-copy ceiling (MSG_TRUNC) P2 585 / P4 594 · single-flow 329 (cut-through hsq12+hsplit14) · TX 582–646&lt;br&gt;&lt;i&gt;Companion prose: HEADER_SPLIT_DESIGN.md (silicon history) · HSPLIT14_DESIGN.md (cut-through) · SESSION_HANDOFF.md (live state + next levers)&lt;/i&gt;" style="text;html=1;fontSize=14;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1880" height="70" as="geometry"/>
        </mxCell>

        <!-- ================= LANE: GATEWARE ================= -->
        <mxCell id="laneGW" value="GATEWARE (sw/litex/milan_soc.py — Migen; rebuild ≈ 1 h, ALWAYS a 2–3-way place-directive sweep, stagger launches 90 s: shared pythondata git)" style="swimlane;horizontal=0;html=1;fillColor=#dae8fc;fontSize=12;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="20" y="90" width="1880" height="470" as="geometry"/>
        </mxCell>

        <mxCell id="gwWire" value="&lt;b&gt;RGMII/MAC&lt;/b&gt;&lt;br&gt;100 MHz datapath&lt;br&gt;(--milan-clk-freq 100e6)&lt;br&gt;&lt;br&gt;exceeds 1 GbE — &lt;b&gt;never the binder&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;" vertex="1" parent="laneGW">
          <mxGeometry x="40" y="40" width="180" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="gwSteer" value="&lt;b&gt;RxSteer (2-queue hash)&lt;/b&gt;&lt;br&gt;hashbit = XOR-parity of 4-tuple bits → q0/q1&lt;br&gt;&lt;br&gt;KNOBS:&lt;br&gt;• hash_sel CSR @0xf0003094 (1 = force q0)&lt;br&gt;• flow placement is PARITY-DETERMINISTIC — pick cports to engineer splits (consecutive ints often share parity!)&lt;br&gt;&lt;br&gt;⚠ steer_q* counters (@0x308c/90) MISREPORT under dual-active — trust only single-active deltas" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;" vertex="1" parent="laneGW">
          <mxGeometry x="240" y="40" width="300" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="gwWriter" value="&lt;b&gt;RingDMAWriter ×2 (per queue) — THE performance core&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;RSC slots (n_slots=4)&lt;/b&gt;: per-flow aggregates; close reasons psh/cap/tout/park/age/prs&lt;br&gt;&lt;b&gt;posted-page FIFO&lt;/b&gt;: 64-deep HW; driver posts KL_BD_POST=60&lt;br&gt;&lt;b&gt;internal CQ&lt;/b&gt;: cq_depth=32/queue, 128-bit LUTRAM (Memory, sync-W/async-R — the −4866-LUT diet, hsq7)&lt;br&gt;&lt;b&gt;BD drain full-gate&lt;/b&gt;: stalls at wr+16==rd_ptr (hsq6 — NEVER laps the driver; pre-gate = the desync storms / silent 256-alias corruption)&lt;br&gt;&lt;b&gt;CQ ordering&lt;/b&gt;: hsq12+ = cut-through (open allocs page only; META ALLOCATES AT CLOSE → pages drain at completion). ≤hsq11 = meta-first (ACK-hold!)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;align=left;" vertex="1" parent="laneGW">
          <mxGeometry x="560" y="40" width="560" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="gwKnobs" value="&lt;b&gt;WRITER KNOBS (per queue: q0 base 0xf0003024, q1 0xf0003098 — SAME layout)&lt;/b&gt;&lt;br&gt;• rsc_bufsz (PAYCAP) @+0x44: 57344 — ⚠ CSR TRUNCATES AT 16 BITS (0x1C000→0xC000); widening = RTL lever for &amp;gt;64K aggregates&lt;br&gt;• rsc_tout @+0x48: idle close, 100 MHz ticks; ethtool -C rx-usecs writes it AND the poll cadence — DECOUPLE by re-poking after ethtool (measured: flat either way at P4-16K)&lt;br&gt;• rsc_segcap @+0x54: 60. segcap=10 measured HARMFUL (256 Mbit)&lt;br&gt;• hs_page_bytes (ELAB param, --hs-page-bytes): crossing compare off_r==PGSZ + 2 mod-PGSZ slices. 4096/16384/32768 built (hsq13/hsq10-12/hsq11)&lt;br&gt;&amp;nbsp;&amp;nbsp;&lt;b&gt;⚠⚠ LETHAL: must equal driver hs_pgsz — mismatch = DMA overrun into kernel memory = panic (2026-07-11). Add a readback CSR + probe-check (open hardening item)&lt;/b&gt;&lt;br&gt;• 16K pages: famine broken (drops 28→5/s @P2); 32K: P8 drops 122→15/s but same ~375 plateau; 4K+cut-through = the zc-flip qualifier (hsq13)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;align=left;fontSize=11;" vertex="1" parent="laneGW">
          <mxGeometry x="560" y="250" width="560" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="gwBD" value="&lt;b&gt;DRAM structures (per queue)&lt;/b&gt;&lt;br&gt;• BD ring: KL_BD_ENTRIES=256 ×16 B (hsplit10+; 64 pre — and 256 was SILENTLY lethal pre-gate: 8-bit seq aliases)&lt;br&gt;• BD encodings: v1 single (w1=buf addr) / v2 meta (len,mss,segs,ack,win,psh,hidx@[63:59]) / v3 page (w1=page addr; hsq12+: fill_len@[31:16], hdr_idx@[63:59])&lt;br&gt;• hs header ring: 32 ×128 B per queue (hs_hdr_base @+0x60)&lt;br&gt;• seq[15:8] + drops[53:48] OR-patched at drain (WB_W)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneGW">
          <mxGeometry x="1140" y="40" width="360" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="gwArea" value="&lt;b&gt;AREA LEDGER (xc7a100t)&lt;/b&gt;&lt;br&gt;hsq6 96.8% slices → CQ-LUTRAM diet −4866 LUTs → strip-probes (--strip-probes, tlm block) −1135 LUTs/−4267 FFs&lt;br&gt;2q fits at ~98%; AREA-70 campaign next: legacy byte-ring removal, CBS 4.4K, dp-CSR 5.9K audits&lt;br&gt;⚠ WNS is placement-noise-dominated here: ALWAYS sweep directives (EPO/AltSpread/ETO; +0.004 vs +0.141 on identical RTL)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneGW">
          <mxGeometry x="1520" y="40" width="330" height="200" as="geometry"/>
        </mxCell>

        <!-- ================= LANE: DRIVER ================= -->
        <mxCell id="laneDRV" value="DRIVER (the-private-test-repo fpga/kl-eth/kl-eth.c — hsplit15 tip; STRICT gateware pairing table in SESSION_HANDOFF)" style="swimlane;horizontal=0;html=1;fillColor=#d5e8d4;fontSize=12;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="20" y="570" width="1880" height="360" as="geometry"/>
        </mxCell>

        <mxCell id="drvPoll" value="&lt;b&gt;NAPI + poll timers&lt;/b&gt;&lt;br&gt;• KL_POLL_FAST_NS=20 µs kick; ACTIVE rearm = coalesce_us (rx-usecs!)&lt;br&gt;• IRQ: q0 owns the line, masked while polling; handler schedules BOTH queues&lt;br&gt;• &lt;b&gt;TOPOLOGY VERDICT&lt;/b&gt;: 2-hart winner = PIPELINE (softirq: ALL NAPI on cpu0, receivers on cpu1). threaded=0. Symmetric fanout LOSES (281–381 vs 220 unpinned vs 206 pinned/hsplit15) — q1 drops = pipeline tail latency, not a bug&lt;br&gt;• napi_w param (hsplit13+): batch depth; 16 measured 355 vs 64→381" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneDRV">
          <mxGeometry x="40" y="40" width="460" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="drvReap" value="&lt;b&gt;BD reap (kl_rx_one_bd)&lt;/b&gt;&lt;br&gt;• page FIFO pairing: v1/v3 verify w1 addr; hs mismatch = FULL resync (never skip-recycle: frees pages open aggregates still DMA into)&lt;br&gt;• desync detector: magic+seq; probes BD_BASE/WR every 64 bad polls&lt;br&gt;• repost: pages_out debt at poll end (fresh pool pages)&lt;br&gt;• reap cost measured ≈5% of cpu0 — &lt;b&gt;never the binder&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneDRV">
          <mxGeometry x="520" y="40" width="400" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="drvHS" value="&lt;b&gt;hs delivery (the consumer-facing choice)&lt;/b&gt;&lt;br&gt;• hsplit param: 0=legacy(order-4 16K bufs) / 1=q0-only / 2=all queues (q_hs(q) scoping = the Oops fix)&lt;br&gt;• hs_pgsz param: MUST match gateware (LETHAL otherwise)&lt;br&gt;• ≤hsplit13: assemble frags, deliver at META (ACK-hold ⇒ ~375 plateau: rate = PAYCAP/fill-cycle)&lt;br&gt;• hsplit14+: CUT-THROUGH — deliver each v3 page immediately (header synth from hs_hdr[hdr_idx], seq+=delivered, PSH stripped on intermediates; rebind on hidx change = lost-meta safe). Single-flow record 329; multi-flow parked (staircase: v3s only at crossings ⇒ first-chunk latency = fill/pages-per-agg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;align=left;fontSize=11;" vertex="1" parent="laneDRV">
          <mxGeometry x="940" y="40" width="520" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="drvTX" value="&lt;b&gt;TX (context)&lt;/b&gt;&lt;br&gt;HW-TSO + 256 cached BDs; capability 582–646&lt;br&gt;2-proc = scheduler lottery (one starves ~82; fq qdisc ABSENT from kernel = follow-up CONFIG_NET_SCH_FQ)&lt;br&gt;⚠ TX needs its ACKs processed: gate TX after EVERY RX change" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneDRV">
          <mxGeometry x="1480" y="40" width="370" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="drvBudget" value="&lt;b&gt;MEASURED CPU BUDGET @381 Mbit (perf 250 Hz + /proc/stat)&lt;/b&gt;: cpu1 (app) ~60% busy — 66% of it = the recv copy (cold DRAM, ~18 cy/8B = 1 miss/line; THE per-byte tax) · cpu0 (NAPI) ~60–84% busy — flat tcp/skb tail, locks 11.5%, driver ≈5% · both ~40% idle ⇒ latency-bound, NOT CPU-bound; CPU ceiling ≈550–600" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;align=left;fontSize=11;" vertex="1" parent="laneDRV">
          <mxGeometry x="40" y="245" width="1810" height="90" as="geometry"/>
        </mxCell>

        <!-- ================= LANE: KERNEL/CONSUMER ================= -->
        <mxCell id="laneK" value="KERNEL + CONSUMER (the lane that decides the record)" style="swimlane;horizontal=0;html=1;fillColor=#ffe6cc;fontSize=12;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="20" y="940" width="1880" height="420" as="geometry"/>
        </mxCell>

        <mxCell id="kGRO" value="&lt;b&gt;GRO/TCP&lt;/b&gt;&lt;br&gt;taps see post-GRO units (avg 18.6 KB measured)&lt;br&gt;GRO ON is a WIN (off = −20)&lt;br&gt;quickack route opt = HARMFUL streaming (294; ACK flood + q1 drops)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;align=left;fontSize=11;" vertex="1" parent="laneK">
          <mxGeometry x="40" y="40" width="330" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="kConsumers" value="&lt;b&gt;CONSUMER LADDER (P2 sustained, keeper config)&lt;/b&gt;&lt;br&gt;• socket copy (recv_spin/iperf): &lt;b&gt;363–381&lt;/b&gt; — pays the cold copy&lt;br&gt;• MSG_TRUNC (recv_trunc): &lt;b&gt;585–594&lt;/b&gt; = the stack ceiling, ABOVE the 500 goal&lt;br&gt;• AF_PACKET TPACKET_V3 (recv_ring): &lt;b&gt;124–139 — REFUTED&lt;/b&gt; (kernel copies INTO the ring on cpu0; consumer-side-only zero-copy)&lt;br&gt;• TCP_ZEROCOPY_RECEIVE (recv_zc, hsq13@4K): &lt;b&gt;110–113 @ 87% flipped — REFUTED&lt;/b&gt; (live kernel zc ≈290 µs/page on 100 MHz sv39, cpu1 100% sys; mapbench's 1.22 µs was the raw path). Next: does 7.0.11 use vm_insert_pages (batched)?&lt;br&gt;• AF_XDP ZC: true driver zero-copy — the big lift if zc-flip falls short" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;align=left;fontSize=11;" vertex="1" parent="laneK">
          <mxGeometry x="390" y="40" width="620" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="kPhysics" value="&lt;b&gt;THE TWO LAWS (derived + verified this campaign)&lt;/b&gt;&lt;br&gt;1. &lt;b&gt;Drop law&lt;/b&gt;: one loss per ~60 ms pins cubic at ~35–50 segs ⇒ aggregate ≈ nflows × 60 Mbit REGARDLESS of queues. Queues only multiply after drops≈0. Drops came from posted-pool famine (absorbency = pages × pgsz vs reap-gap bursts).&lt;br&gt;2. &lt;b&gt;ACK-hold law&lt;/b&gt;: any store-and-forward hold enters TCP's RTT ⇒ rate = HOLD_BYTES/fill-cycle self-equilibrium (~375 at every flow count). Exits: cut-through delivery (kills the hold) or non-TCP-paced consumers (MSG_TRUNC shows 585).&lt;br&gt;&lt;br&gt;&lt;b&gt;Failure-mode index&lt;/b&gt;: desync storms=BD lap (pre-hsq6) · pairing lost=hs FIFO desync (full resync) · Bad page map panic = page-size pairing violation · q1&amp;gt;&amp;gt;q0 drops = pipeline tail (expected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;align=left;fontSize=11;" vertex="1" parent="laneK">
          <mxGeometry x="1030" y="40" width="820" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="kNext" value="&lt;b&gt;WHERE TO EXTRACT MORE (ranked, with the file/knob to touch)&lt;/b&gt;&lt;br&gt;1. recv_zc on hsq13 (4K cut-through) — tools_recv_zc.c; expect 500–700 if the flip batches; measure zc% + Mbit vs 585 ceiling&lt;br&gt;2. PAYCAP CSR widening (milan_soc.py rsc_bufsz width) → 128K aggregates → fewer units/byte for the copy lane&lt;br&gt;3. Cut-through multi-flow: 8K pages (finer staircase) or driver chunk-batching (hsplit14 v3 handler) — reclaim P4 on the 329-record lane&lt;br&gt;4. CONFIG_NET_SCH_FQ kernel rebuild → TX 2-proc fairness → stable 620+ TX&lt;br&gt;5. AREA-70 → headroom for AVDECC product blocks (the actual goal of the chip)&lt;br&gt;6. hs_page_bytes readback CSR + driver probe-check (the panic hardening) — DO BEFORE any further page-size experiments" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;align=left;fontSize=11;" vertex="1" parent="laneK">
          <mxGeometry x="40" y="245" width="1810" height="150" as="geometry"/>
        </mxCell>

        <!-- arrows -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="laneGW" source="gwWire" target="gwSteer"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="laneGW" source="gwSteer" target="gwWriter"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" parent="laneGW" source="gwWriter" target="gwBD"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
